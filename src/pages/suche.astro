---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Spotlight Suche - Nookipedia">
  <PageHero accent="guide" emoji="🔍" title="Nook-Spotlight Suche" subtitle="Durchsuche Fauna, Flora, Rezepte, Kunst und Fossilien auf deiner Insel.">
    <form id="search-page-form" class="search-form">
      <input type="text" id="search-page-input" placeholder="Suche anpassen…" autocomplete="off" spellcheck="false" required />
      <button type="submit" aria-label="Suchen">🔍</button>
    </form>
    <p id="search-status" class="search-status"></p>
  </PageHero>

  <section style="max-width: 900px; margin: 0 auto var(--sp-12);">
    <div id="search-loading" class="hide text-center" style="padding: var(--sp-10);">
      <div class="loader-spinner"></div>
      <p class="muted" style="font-weight: 700;">Die Nook-Datenbank wird durchsucht…</p>
    </div>

    <div id="search-no-results" class="empty-state hide">
      <span class="emoji">🦝</span>
      <h3>Oh weh! Resetti hat nichts gefunden.</h3>
      <p class="muted" style="margin: var(--sp-2) 0 var(--sp-5);">Versuche es mit einem anderen Begriff oder überprüfe die Schreibweise.</p>
      <a href="/" class="ac-btn ac-btn--primary accent-guide">Zurück zum Dorfplatz</a>
    </div>

    <div id="search-results-grid" class="grid-auto" style="--min: 260px;"></div>
  </section>
</Layout>

<style>
  .search-form { display: flex; max-width: 500px; margin: var(--sp-6) auto 0; background: #fff; border-radius: var(--radius-pill); overflow: hidden; box-shadow: var(--ac-shadow); }
  .search-form input { flex: 1; border: none; padding: 0.85rem 1.4rem; font: inherit; font-weight: 700; color: #1b2a21; outline: none; }
  .search-form button { border: none; padding: 0 1.4rem; font-size: 1.2rem; color: #fff; background: var(--accent); cursor: pointer; transition: background var(--t-fast); }
  .search-form button:hover { background: var(--accent-deep); }
  .search-status { margin-top: var(--sp-4); font-weight: 700; color: rgba(255,255,255,0.95); }
  .loader-spinner { width: 42px; height: 42px; margin: 0 auto var(--sp-4); border: 4px solid var(--ac-border); border-top-color: var(--ac-green); border-radius: 50%; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .search-page-card { display: flex; align-items: center; gap: var(--sp-4); position: relative; padding: var(--sp-4); background: var(--ac-surface); border: 2px solid var(--ac-border); border-radius: var(--radius-lg); box-shadow: var(--ac-shadow); text-decoration: none; color: var(--ac-text); transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base); }
  .search-page-card:hover { transform: translateY(-3px); border-color: var(--ac-green); }
  .search-page-img { flex-shrink: 0; display: grid; place-items: center; width: 60px; height: 60px; padding: 6px; background: var(--ac-surface-2); border-radius: var(--radius-sm); }
  .search-page-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .sp-title { margin: 0 0 2px; font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; }
  .sp-sub { font-size: 0.85rem; color: var(--ac-text-muted); font-weight: 700; }
  .sp-badge { position: absolute; top: 12px; right: 12px; padding: 2px 10px; font-size: 0.72rem; font-weight: 800; color: #fff; background: var(--ac-green); border-radius: var(--radius-pill); }
  .sp-badge[data-type="Insekt"] { background: #63bb47; }
  .sp-badge[data-type="Fisch"] { background: #3d9be0; }
  .sp-badge[data-type="Meerestier"] { background: #9b6dc4; }
  .sp-badge[data-type="Flora"] { background: #ef74a7; }
  .sp-badge[data-type="Kunst"] { background: #c79a2b; }
  .sp-badge[data-type="Fossil"] { background: #a98253; }
</style>

<script>
  const directusUrl = 'https://backend-nookipedia.2.godsize.info';

  const getImageUrl = (path) => {
    if (!path) return '/assets/img/acnh/koeder.png';
    if (path.startsWith('http')) return path;
    if (path.includes('/') || path.includes('.')) {
      let clean = path.startsWith('/') ? path.slice(1) : path;
      if (clean.startsWith('assets/')) clean = clean.slice(7);
      if (clean.startsWith('img/acnh/')) clean = clean.slice(9);
      return `/assets/img/acnh/${clean}`;
    }
    return `${directusUrl}/assets/${path}`;
  };

  const staticFallbackDB = [
    { title: 'Rose', subtitle: 'Zuchtblume', type: 'Flora', url: '/blumen/1', image: '/assets/img/acnh/flowers/Rose.png' },
    { title: 'Tulpe', subtitle: 'Zuchtblume', type: 'Flora', url: '/blumen/2', image: '/assets/img/acnh/flowers/Tulpe.png' },
    { title: 'Maiglöckchen', subtitle: 'Zuchtblume', type: 'Flora', url: '/blumen/9', image: '/assets/img/acnh/flowers/Maigloeckchen.png' },
    { title: 'Gemüsegemälde', subtitle: 'Kunstwerk (Der Sommer)', type: 'Kunst', url: '/museum/kunst/1', image: '/assets/img/acnh/museum/Gemuesegemaelde_real.png' },
    { title: 'T-Rex-Schädel', subtitle: 'Dino-Fossil (T-Rex)', type: 'Fossil', url: '/museum/fossilien', image: '/assets/img/acnh/museum/T-Rex-Schaedel.png' },
  ];

  async function performSearchQuery(query) {
    const statusEl = document.getElementById('search-status');
    const loadingEl = document.getElementById('search-loading');
    const noResultsEl = document.getElementById('search-no-results');
    const gridEl = document.getElementById('search-results-grid');
    if (!statusEl || !loadingEl || !noResultsEl || !gridEl) return;

    gridEl.innerHTML = '';
    noResultsEl.classList.add('hide');

    if (!query || query.length < 2) {
      statusEl.textContent = 'Bitte gib mindestens 2 Zeichen ein.';
      return;
    }

    statusEl.textContent = '';
    loadingEl.classList.remove('hide');
    let results = [];

    try {
      const endpoints = [
        `${directusUrl}/items/creatures?filter[name][_icontains]=${encodeURIComponent(query)}&limit=15`,
        `${directusUrl}/items/flowers?filter[name][_icontains]=${encodeURIComponent(query)}&limit=5`,
        `${directusUrl}/items/diy_recipes?filter[name][_icontains]=${encodeURIComponent(query)}&limit=10`,
        `${directusUrl}/items/cooking_recipes?filter[name][_icontains]=${encodeURIComponent(query)}&limit=10`,
        `${directusUrl}/items/artworks?filter[name][_icontains]=${encodeURIComponent(query)}&limit=5`,
        `${directusUrl}/items/fossils?filter[name][_icontains]=${encodeURIComponent(query)}&limit=5`,
      ];
      const responses = await Promise.all(endpoints.map((url) => fetch(url).then((r) => (r.ok ? r.json() : { data: [] })).catch(() => ({ data: [] }))));
      const [creatures, flowers, diy, cooking, artworks, fossils] = responses.map((r) => r.data || []);

      creatures.forEach((c) => results.push({ title: c.name, subtitle: `${c.price || 0} Sternis`, type: c.category === 'insect' ? 'Insekt' : c.category === 'fish' ? 'Fisch' : 'Meerestier', url: `/tier/${c.id}/`, image: getImageUrl(c.image_path) }));
      flowers.forEach((f) => results.push({ title: f.name, subtitle: 'Zuchtblume', type: 'Flora', url: `/blumen/${f.id}/`, image: getImageUrl(f.image_path) }));
      diy.forEach((d) => results.push({ title: d.name, subtitle: d.source || 'Bastelanleitung', type: 'Rezept', url: '/items/', image: getImageUrl(d.image_path) }));
      cooking.forEach((ck) => results.push({ title: ck.name, subtitle: ck.source || 'Kochrezept', type: 'Rezept', url: '/items/', image: getImageUrl(ck.image_path) }));
      artworks.forEach((art) => results.push({ title: art.name, subtitle: `Kunstwerk von ${art.artist}`, type: 'Kunst', url: `/museum/kunst/${art.id}`, image: getImageUrl(art.image_real) }));
      fossils.forEach((f) => results.push({ title: f.name, subtitle: 'Dino-Fossil', type: 'Fossil', url: '/museum/fossilien', image: getImageUrl(f.image_path) }));
    } catch (err) {
      console.warn('Directus search error, using static fallback.', err);
    }

    const queryLower = query.toLowerCase();
    staticFallbackDB
      .filter((item) => item.title.toLowerCase().includes(queryLower) || item.subtitle.toLowerCase().includes(queryLower))
      .forEach((sf) => { if (!results.some((r) => r.title.toLowerCase() === sf.title.toLowerCase())) results.push(sf); });

    loadingEl.classList.add('hide');

    if (results.length === 0) {
      noResultsEl.classList.remove('hide');
      statusEl.textContent = `Keine Ergebnisse für „${query}"`;
      return;
    }

    statusEl.textContent = `${results.length} Ergebnisse für „${query}"`;
    const frag = document.createDocumentFragment();
    results.forEach((res) => {
      const card = document.createElement('a');
      card.href = res.url;
      card.className = 'search-page-card';
      card.innerHTML = `
        <span class="search-page-img"><img src="${res.image}" alt="" onerror="this.src='/assets/img/acnh/koeder.png'" /></span>
        <span><span class="sp-title">${res.title}</span><br><span class="sp-sub">${res.subtitle}</span></span>
        <span class="sp-badge" data-type="${res.type}">${res.type}</span>`;
      frag.appendChild(card);
    });
    gridEl.appendChild(frag);
  }

  function initSearchPage() {
    const form = document.getElementById('search-page-form');
    const input = document.getElementById('search-page-input');
    if (!form || !input) return;
    const query = new URLSearchParams(window.location.search).get('q');
    if (query) { input.value = query; performSearchQuery(query); }
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (q) {
        window.history.pushState({}, '', `${window.location.pathname}?q=${encodeURIComponent(q)}`);
        performSearchQuery(q);
      }
    });
  }

  document.addEventListener('astro:page-load', initSearchPage);
  initSearchPage();
</script>
