---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides');
// Keep the overview tidily ordered by the flower id the guide belongs to.
allGuides.sort((a, b) => a.data.flowerId - b.data.flowerId);
---

<Layout title="Zucht-Guides Übersicht">
  <a href="/blumen/" class="ac-btn back-btn accent-flower">← Pflanzenwelt &amp; Zucht</a>

  <PageHero
    accent="flower"
    emoji="📖"
    title="Zucht-Guides"
    subtitle="Detaillierte Profi-Wege für jede Blumenart – von der Samentüte zur seltensten Hybride."
  />

  <section class="guide-grid accent-flower">
    {allGuides.map((guide) => (
      <a href={`/guides/${guide.slug}`} class="guide-card">
        <span class="guide-icon">{guide.data.icon || '🍃'}</span>
        <span class="guide-body">
          <strong class="guide-title">{guide.data.title}</strong>
          <span class="muted guide-desc">{guide.data.description}</span>
          <span class="ac-badge guide-cta">Guide lesen →</span>
        </span>
      </a>
    ))}
  </section>
</Layout>

<style>
  .back-btn { margin: var(--sp-4) 0 var(--sp-6); }

  .guide-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    margin-bottom: var(--sp-12);
  }
  @media (min-width: 720px) { .guide-grid { grid-template-columns: repeat(2, 1fr); } }

  .guide-card {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    padding: var(--sp-5);
    background: var(--ac-surface);
    border: 1px solid var(--ac-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--ac-shadow);
    text-decoration: none;
    color: var(--ac-text);
    transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base), box-shadow var(--t-base);
  }
  .guide-card:hover { transform: translateY(-5px); border-color: color-mix(in srgb, var(--accent) 55%, var(--ac-border)); box-shadow: var(--ac-shadow-lg); }
  .guide-card:active { transform: scale(0.98); }

  .guide-icon {
    flex-shrink: 0;
    display: grid; place-items: center;
    width: 60px; height: 60px;
    font-size: 2rem;
    background: var(--accent-soft);
    border-radius: var(--radius-md);
  }
  .guide-body { display: flex; flex-direction: column; gap: 6px; }
  .guide-title { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; line-height: 1.2; }
  .guide-desc { font-size: 0.92rem; line-height: 1.45; }
  .guide-cta { align-self: flex-start; margin-top: 2px; }
</style>
