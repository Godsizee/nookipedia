---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allGuides = await getCollection('guides');
  return allGuides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();
---

<Layout title={guide.data.title}>
  <a href="/guides/" class="ac-btn back-btn accent-flower">← Alle Zucht-Guides</a>

  <section class="page-hero accent-flower guide-hero">
    <span class="hero-emoji">{guide.data.icon || '🍃'}</span>
    <h1>{guide.data.title}</h1>
    <p>{guide.data.description}</p>
  </section>

  <article class="ac-card accent-flower guide-body">
    <div class="markdown-content">
      <Content />
    </div>

    <div class="guide-footer">
      <a href={`/blumen/${guide.data.flowerId}/`} class="ac-btn ac-btn--primary">
        🌸 Zuchtdaten für {guide.data.flowerName} ansehen →
      </a>
    </div>
  </article>
</Layout>

<!-- Markdown content is rendered by <Content />, so it needs global rules -->
<style is:global>
  .markdown-content h2 {
    display: flex; align-items: center; gap: 8px;
    color: var(--accent-deep);
    font-size: 1.35rem;
    margin: var(--sp-8) 0 var(--sp-4);
    padding-bottom: var(--sp-2);
    border-bottom: 2px dashed var(--ac-border);
  }
  .markdown-content h2:first-child { margin-top: 0; }
  .markdown-content h3 {
    display: flex; align-items: center; gap: 8px;
    color: var(--ac-text);
    font-size: 1.1rem;
    margin: var(--sp-6) 0 var(--sp-3);
  }
  .markdown-content p { font-size: 1.02rem; line-height: 1.65; margin-bottom: var(--sp-4); color: var(--ac-text); }
  .markdown-content ul, .markdown-content ol { margin: 0 0 var(--sp-5); padding-left: var(--sp-6); }
  .markdown-content li { line-height: 1.55; margin-bottom: var(--sp-2); color: var(--ac-text); }
  .markdown-content li::marker { color: var(--accent); }
  .markdown-content strong { font-weight: 800; color: var(--accent-deep); }
  .markdown-content em { color: var(--ac-text-muted); }
  .markdown-content blockquote {
    margin: var(--sp-5) 0;
    padding: var(--sp-4) var(--sp-5);
    background: var(--accent-soft);
    border-left: 6px solid var(--accent);
    border-radius: var(--radius-md);
  }
  .markdown-content blockquote p { margin: 0; }
</style>

<style>
  .back-btn { margin: var(--sp-4) 0 var(--sp-6); }
  .guide-hero { padding-block: var(--sp-8) var(--sp-10); }
  .guide-body { max-width: 820px; margin-inline: auto; }
  .guide-footer {
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: 2px dashed var(--ac-border);
    display: flex; justify-content: center;
  }
</style>
