---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getRecipes, DEFAULT_DIRECTUS } from '../lib/api.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const recipes = await getRecipes(directusUrl);
---

<Layout title="Alle Rezepte - Nookipedia">
  <PageHero accent="recipe" emoji="📒" title="Alle Rezepte" subtitle="Jede Bastelanleitung und jedes Kochrezept auf einen Blick." />

  <div class="grid-auto accent-recipe" style="--min: 240px; margin-bottom: var(--sp-12);">
    {recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
  </div>

  {recipes.length === 0 && (
    <div class="empty-state"><span class="emoji">📒</span> Noch keine Rezepte verfügbar.</div>
  )}
</Layout>
