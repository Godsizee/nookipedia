---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getMaterials, DEFAULT_DIRECTUS } from '../lib/api.js';
import { getImageUrl } from '../lib/format.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const allMaterials = await getMaterials(directusUrl);

const categories = [
  { key: 'normal',   name: '🪵 Basis-Materialien & Zutaten',  desc: 'Ressourcen, die du das ganze Jahr über sammeln kannst.',          items: allMaterials.filter((m) => m.category === 'normal') },
  { key: 'seasonal', name: '❄️ Saisonale Materialien',         desc: 'Ressourcen für spezielle Feiertags- und Saisonanleitungen.',     items: allMaterials.filter((m) => m.category === 'seasonal') },
  { key: 'other',    name: '✨ Sonstige Ressourcen',           desc: 'Weitere nützliche Werkstoffe für dein Inselleben.',              items: allMaterials.filter((m) => m.category === 'other' || !m.category) },
].filter((c) => c.items.length > 0);
---

<Layout title="Materialien & Zutaten - Bastel-Wiki">
  <PageHero accent="material" emoji="🪵" title="Materialien & Zutaten" subtitle="Alles, was du zum Basteln von Werkzeugen und Möbeln benötigst!" />

  <div class="stack stack-6" style="max-width: 900px; margin: 0 auto var(--sp-12);">
    {categories.map((cat) => (
      <details class="ac-card accent-material mat-group" open>
        <summary><span>{cat.name}</span> <span class="chevron">▾</span></summary>
        <p class="muted text-center" style="font-style: italic; margin: var(--sp-3) 0 var(--sp-5);">{cat.desc}</p>
        <div class="grid-auto" style="--min: 210px; --gap: var(--sp-3);">
          {cat.items.map((mat) => (
            <div class="mat-card" id={`mat-${mat.id}`}>
              <span class="mat-img"><img src={getImageUrl(mat.image_path)} alt={mat.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" /></span>
              <span class="stack stack-2 grow">
                <span class="mat-name">{mat.name}</span>
                <span class="muted" style="font-size: 0.75rem;">📍 {mat.source || 'Unbekannt'}</span>
                <span class="price-tag" style="font-size: 0.72rem;">💰 {mat.sell_price || '0 Sternis'}</span>
              </span>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
</Layout>

<style>
  .mat-group summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; list-style: none; font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; }
  .mat-group summary::-webkit-details-marker { display: none; }
  .mat-group .chevron { color: var(--ac-text-muted); transition: transform var(--t-base); }
  .mat-group[open] .chevron { transform: rotate(180deg); }
  .mat-card { display: flex; align-items: center; gap: 10px; padding: 10px; background: var(--ac-surface-2); border: 2px solid transparent; border-radius: var(--radius-md); transition: border-color var(--t-fast), transform var(--t-fast) var(--ease-spring); }
  .mat-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .mat-img { flex-shrink: 0; display: grid; place-items: center; width: 48px; height: 48px; padding: 5px; background: var(--ac-surface); border-radius: var(--radius-sm); }
  .mat-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .mat-name { font-weight: 800; font-size: 0.92rem; line-height: 1.2; }
  .mat-card .price-tag { width: fit-content; }
</style>
