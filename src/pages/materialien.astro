---
import Layout from '../layouts/Layout.astro';

const categories = [
    {
        key: 'normal',
        name: '🪵 Basis-Materialien & Zutaten',
        desc: 'Ressourcen, die du das ganze Jahr über auf deiner Insel sammeln kannst.',
        items: [
            { id: 1, name: 'Ast', source: 'Bäume schütteln', price: '5 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 2, name: 'Weichholz', source: 'Bäume hacken', price: '60 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 3, name: 'Hartholz', source: 'Bäume hacken', price: '60 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 4, name: 'Holz', source: 'Bäume hacken', price: '60 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 5, name: 'Eisenerz', source: 'Steine schlagen', price: '375 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 6, name: 'Golderz', source: 'Steine schlagen (selten)', price: '10.000 Sternis', image_path: '64px-99k_Bells_NH_Inv_Icon.png' }
        ]
    },
    {
        key: 'seasonal',
        name: '❄️ Saisonale Materialien',
        desc: 'Ressourcen für spezielle Feiertags- und Saisonanleitungen.',
        items: [
            { id: 7, name: 'Kirschblütenblatt', source: 'Mit Kescher fangen (April)', price: '200 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 8, name: 'Eichel', source: 'Laubbäume schütteln (Herbst)', price: '200 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' },
            { id: 9, name: 'Sternensplitter', source: 'Sternschnuppen wünschen', price: '250 Sternis', image_path: '64px-Tree_Branch_NH_Inv_Icon.png' }
        ]
    }
];
---

<Layout title="Materialien & Zutaten - Bastel-Wiki">
    <div class="hero">
        <h1>Materialien & Zutaten</h1>
        <p>Alles, was du zum Basteln von Werkzeugen und Möbeln auf deiner Insel benötigst!</p>
    </div>

    <div class="events-container" style="max-width:900px; margin: 2rem auto 4rem; display:flex; flex-direction:column; gap:1.5rem;">
        {categories.map((cat) => (
            <details class="month-group material-group" style="background: var(--ac-surface); border-radius: var(--radius-lg); box-shadow: var(--ac-shadow); overflow: hidden;" open>
                <summary class="month-summary" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 900; font-size: 1.2rem; border-bottom: 1px solid rgba(0,0,0,0.05);">
                    <span>{cat.name}</span>
                    <span style="font-size: 0.9rem; color: var(--ac-text-muted);">▼</span>
                </summary>
                
                <div class="month-grid" style="padding: 1.5rem; background: var(--ac-bg);">
                    <p style="margin-top:0; margin-bottom: 1.5rem; color: var(--ac-text-muted); text-align: center; font-style: italic;">
                        {cat.desc}
                    </p>
                    
                    <div class="material-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;">
                        {cat.items.map((mat) => (
                            <div class="material-card" id={`mat-${mat.id}`} style="background: var(--ac-surface); border: 1px solid var(--ac-border); border-radius: var(--radius-md); padding: 12px; display: flex; align-items: center; gap: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.04);">
                                <div class="material-img" style="width: 48px; height: 48px; background: var(--ac-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <span style="font-size:1.5rem;">🪵</span>
                                </div>
                                <div class="material-details" style="display: flex; flex-direction: column; gap: 4px; flex-grow: 1;">
                                    <span class="material-name" style="font-weight: 900; font-size: 0.95rem;">{mat.name}</span>
                                    <span class="material-source" style="font-size: 0.75rem; color: var(--ac-text-muted);">📍 {mat.source}</span>
                                    <span class="material-price" style="font-size: 0.75rem; color: var(--ac-bell); font-weight: 900; background: var(--ac-bell-bg, rgba(242, 192, 70, 0.15)); padding: 2px 6px; border-radius: 4px; width: fit-content;">💰 {mat.price}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </details>
        ))}
    </div>
</Layout>
