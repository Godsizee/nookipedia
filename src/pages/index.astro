---
import Layout from '../layouts/Layout.astro';

/** Home "Nook Phone" launcher — one row of data drives the whole grid. */
const apps = [
  { href: '/museum/',      accent: 'museum',   emoji: '🏛️', img: null,                                         label: 'Das Museum',          sub: 'Eugens Sammlungen' },
  { href: '/faunapaedie/', accent: 'insect',   emoji: null,  img: '/assets/img/acnh/home/vogelfalter.png',     label: 'Faunapädie',          sub: 'Fische · Insekten · Meer' },
  { href: '/blumen/',      accent: 'flower',   emoji: null,  img: '/assets/img/acnh/home/Red_Cosmos_NL_Icon.png', label: 'Pflanzenwelt',      sub: 'Blumen & Hybriden' },
  { href: '/events/',      accent: 'event',    emoji: null,  img: '/assets/img/acnh/home/64px-Red_Balloon_NH_Icon.png', label: 'Feiertage & Events', sub: 'Der Festkalender' },
  { href: '/materialien/', accent: 'material', emoji: null,  img: '/assets/img/acnh/home/64px-Tree_Branch_NH_Inv_Icon.png', label: 'Materialien',  sub: 'Zutaten & Rohstoffe' },
  { href: '/rezepte',      accent: 'recipe',   emoji: null,  img: '/assets/img/acnh/home/BastelnKochen.png',    label: 'Basteln & Kochen',    sub: 'DIY & Rezepte' },
  { href: '/villager/',    accent: 'villager', emoji: '🐾',  img: null,                                         label: 'Bewohner',            sub: 'Alle Inselnachbarn' },
  { href: '/katalog/',     accent: 'material', emoji: '🛋️',  img: null,                                         label: 'Item-Katalog',        sub: 'Möbel & Gegenstände' },
  { href: '/guides/',      accent: 'guide',    emoji: '📖',  img: null,                                         label: 'Zucht-Guides',        sub: 'Schritt für Schritt' },
  { href: '/erfolge/',     accent: 'achievement', emoji: '🏅', img: null,                                      label: 'Erfolge',             sub: 'Nook-Meilen-Stempel' },
];
---

<Layout title="Willkommen auf Nookipedia">
  <section class="hero">
    <span class="hero-emoji floating" style="font-size:4.5rem">🏝️</span>
    <h1>Nookipedia Next-Level</h1>
    <p>Dein ultimativer, fabelhafter und pfeilschneller Begleiter für Animal Crossing: New Horizons.</p>
  </section>

  <nav class="app-grid" aria-label="Hauptkategorien">
    {apps.map((a) => (
      <a href={a.href} class={`app-tile accent-${a.accent}`}>
        <span class="tile-icon">
          {a.img
            ? <img src={a.img} alt="" loading="lazy" onerror="this.src='/assets/img/acnh/placeholder.png'" />
            : a.emoji}
        </span>
        <span class="stack stack-2">
          <span class="tile-label">{a.label}</span>
          <span class="tile-sub">{a.sub}</span>
        </span>
      </a>
    ))}
  </nav>

  <p class="text-center muted mt-10" style="font-weight:700">
    Wähle eine Kategorie, um zu sehen, was du gerade auf deiner Insel entdecken kannst! 🌟
  </p>
</Layout>
