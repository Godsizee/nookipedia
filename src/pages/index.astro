---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Willkommen auf Nookipedia">
    <section class="hero">
        <div style="font-size: 4.5rem; margin-bottom: 15px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🏝️</div>
        <h1>Nookipedia Next-Level</h1>
        <p>Dein ultimativer, fabelhafter und pfeilschneller Begleiter für Animal Crossing: New Horizons.</p>
    </section>

    <div class="category-selection">
        <a href="/museum/" class="cat-card cat-card-museum">
            <i>
                <span style="font-size: 2.2rem; line-height: 1; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.1));">🏛️</span>
            </i>
            <span>Das Museum</span>
        </a>

        <a href="/faunapaedie/" class="cat-card faunapaedie">
            <i><img src="/assets/img/acnh/home/vogelfalter.png" alt="Faunapädie" style="max-width: 80%; max-height: 80%; object-fit: contain;" onerror="this.src='/assets/img/acnh/placeholder.png'" /></i>
            <span>Faunapädie</span>
        </a>
        
        <a href="/blumen/" class="cat-card flowers">
            <i><img src="/assets/img/acnh/home/Red_Cosmos_NL_Icon.png" alt="Pflanzenwelt" style="max-width: 80%; max-height: 80%; object-fit: contain;" onerror="this.src='/assets/img/acnh/placeholder.png'" /></i>
            <span>Pflanzenwelt</span>
        </a>

        <a href="/events/" class="cat-card events">
            <i><img src="/assets/img/acnh/home/64px-Red_Balloon_NH_Icon.png" alt="Feiertage & Events" style="max-width: 80%; max-height: 80%; object-fit: contain;" onerror="this.src='/assets/img/acnh/placeholder.png'" /></i>
            <span>Feiertage & Events</span>
        </a>

        <a href="/materialien/" class="cat-card" style="border-color: rgba(41, 182, 246, 0.4);">
            <i><img src="/assets/img/acnh/home/64px-Tree_Branch_NH_Inv_Icon.png" alt="Materialien & Zutaten" style="max-width: 80%; max-height: 80%; object-fit: contain;" onerror="this.src='/assets/img/acnh/placeholder.png'" /></i>
            <span>Materialien & Zutaten</span>
        </a>

        <a href="/items/" class="cat-card" style="border-color: rgba(255, 152, 0, 0.4);">
            <i><img src="/assets/img/acnh/home/BastelnKochen.png" alt="Bastelanleitungen & Kochrezepte" style="max-width: 80%; max-height: 80%; object-fit: contain;" onerror="this.src='/assets/img/acnh/placeholder.png'" /></i>
            <span>Basteln & Kochen</span>
        </a>

        <a href="/guides/" class="cat-card" style="border-color: rgba(89, 166, 131, 0.4);">
            <i>
                <span style="font-size: 2.2rem; line-height: 1; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.1));">📖</span>
            </i>
            <span>Zucht-Guides</span>
        </a>
    </div>

    <div style="margin-top: 50px; text-align: center;">
        <p style="color: var(--ac-text-muted); font-size: 1rem; font-weight: 600;">
            Wähle eine Kategorie aus, um zu sehen, was du gerade auf deiner Insel entdecken kannst!
        </p>
    </div>
</Layout>
