---
import Layout from '../layouts/Layout.astro';

const monthNames = [
    { num: 1, name: 'Januar', icon: '⛄', events: [{ name: 'Neujahr', desc: 'Feiere das neue Jahr mit deinen Nachbarn auf dem Festplatz!', time: '1. Januar' }] },
    { num: 2, name: 'Februar', icon: '💝', events: [{ name: 'Karneval', desc: 'Pavo tanzt und sammelt Federn!', time: 'Februar' }] },
    { num: 3, name: 'März', icon: '☘️', events: [] },
    { num: 4, name: 'April', icon: '🌸', events: [{ name: 'Häschentag', desc: 'Ohs der Hase versteckt Eier auf der gesamten Insel.', time: 'April' }] },
    { num: 5, name: 'Mai', icon: '🌿', events: [] },
    { num: 6, name: 'Juni', icon: '☀️', events: [{ name: 'Insektikusturnier', desc: 'Carleon veranstaltet das große Sommer-Turnier.', time: '4. Samstag im Juni' }] },
    { num: 7, name: 'Juli', icon: '🐚', events: [{ name: 'Angelturnier', desc: 'Lomeus veranstaltet das große Sommer-Angelturnier.', time: '2. Samstag im Juli' }] },
    { num: 8, name: 'August', icon: '🎇', events: [{ name: 'Feuerwerksfest', desc: 'Jeden Sonntag im August gibt es ein spektakuläres Feuerwerk.', time: 'Sonntags im August' }] },
    { num: 9, name: 'September', icon: '🍇', events: [] },
    { num: 10, name: 'Oktober', icon: '🎃', events: [{ name: 'Halloween', desc: 'Jakob der Prinz der Kürbisse besucht die Insel.', time: '31. Oktober' }] },
    { num: 11, name: 'November', icon: '🍄', events: [{ name: 'Schlemmfest', desc: 'Gernod kocht ein fabelhaftes Festmahl.', time: '4. Donnerstag im November' }] },
    { num: 12, name: 'Dezember', icon: '🎄', events: [{ name: 'Spielzeugtag', desc: 'Chris das Rentier verteilt Geschenke.', time: '24. Dezember' }] }
];
---

<Layout title="Feiertage & Events - Festkalender">
    <div class="hero">
        <h1>Feiertage & Events</h1>
        <p>Verpasse keine Turniere, Partys und besonderen Gäste auf deiner Insel mehr!</p>
    </div>

    <div class="events-container" style="max-width:850px; margin: 2rem auto 4rem; display:flex; flex-direction:column; gap:1.5rem;">
        {monthNames.map((m) => (
            <details class="month-group" style="background: var(--ac-surface); border-radius: var(--radius-lg); box-shadow: var(--ac-shadow); overflow: hidden;">
                <summary class="month-summary" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 900; font-size: 1.2rem; border-bottom: 1px solid rgba(0,0,0,0.05);">
                    <span style="display: flex; align-items: center; gap: 10px;">
                        <span>{m.icon}</span> {m.name}
                    </span>
                    <span style="font-size: 0.9rem; color: var(--ac-text-muted);">▼</span>
                </summary>
                
                <div class="month-grid" style="padding: 1.5rem; background: var(--ac-bg);">
                    {m.events.length > 0 ? (
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem;">
                            {m.events.map((ev) => (
                                <div style="background: var(--ac-surface); padding: 1.25rem; border-radius: var(--radius-md); box-shadow: 0 2px 8px rgba(0,0,0,0.05); border-left: 4px solid var(--ac-green);">
                                    <h3 style="margin: 0 0 4px; font-size: 1.15rem; font-weight: 900;">{ev.name}</h3>
                                    <div style="font-size: 0.85rem; color: var(--ac-green); font-weight: 800; margin-bottom: 8px;">📅 {ev.time}</div>
                                    <p style="margin: 0; font-size: 0.9rem; color: var(--ac-text-muted);">{ev.desc}</p>
                                </div>
                            ))}
                        </div>
                    ) : (
                        <p style="text-align: center; color: var(--ac-text-muted); margin: 0; font-style: italic;">Keine größeren Events in diesem Monat.</p>
                    )}
                </div>
            </details>
        ))}
    </div>
</Layout>
