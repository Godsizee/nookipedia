---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import InfoBox from '../components/InfoBox.astro';
import FlowerCard from '../components/FlowerCard.astro';
import { getFlowers, DEFAULT_DIRECTUS } from '../lib/api.js';
import { getImageUrl } from '../lib/format.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const flowers = await getFlowers(directusUrl);

const tips = [
  { title: '🧬 Hybriden züchten', text: 'Schnapp dir die Gießkanne! Durch geschicktes Aneinanderpflanzen und tägliches Gießen erschaffst du neue Farben wie Pink, Schwarz oder die extrem seltene blaue Rose.' },
  { title: '⭐ Prestige-Tipp', text: 'Bei einem makellosen 5-Sterne-Rating wachsen an deinen Klippen ganz von allein die edlen <em>Maiglöckchen</em> – ein wahres Statussymbol!' },
];
---

<Layout title="Blumen & Pflanzenwelt - Zucht-Guides">
  <PageHero accent="flower" emoji="💐" title="Pflanzenwelt & Zucht" subtitle="Verwandle deine Insel in ein fabelhaftes florales Paradies." />

  <InfoBox accent="flower" emoji="🌷" title="Die botanische Oase" tips={tips}>
    <p>Willkommen in der farbenfrohen Pflanzenwelt! Blumen verschönern nicht nur deine Insellandschaft, sondern locken auch exklusive und seltene Insekten an.</p>
  </InfoBox>

  <details class="ac-card accent-flower cheat-sheet">
    <summary><span class="cluster">🗺️ TL;DR: Der ultimative Zuchtleitfaden auf einen Blick</span><span class="chevron">▾</span></summary>
    <div class="cheat-body">
      <p class="muted">Klicke auf das Bild, um die platzsparendsten Layouts und Kreuzungen für alle Blumenarten zu sehen!</p>
      <a href="/assets/img/acnh/flowers/TLDR/BlumenZuchtleitfaden.png" target="_blank" rel="noopener" class="cheat-img">
        <img src="/assets/img/acnh/flowers/TLDR/BlumenZuchtleitfaden.png" alt="ACNH Blumen Zuchtleitfaden" onerror="this.src='/assets/img/acnh/koeder.png'" />
      </a>
    </div>
  </details>

  <div class="ac-card accent-flower mb-8">
    <div class="text-center mb-6">
      <h3>Schnellnavigation</h3>
      <p class="muted">Springe direkt zur gewünschten Blumenart</p>
    </div>
    <div class="mini-grid" style="max-width: 800px; margin-inline: auto;">
      {flowers.map((f) => (
        <a href={`#flower-${f.id}`} class="mini-card" data-id={f.id} title={f.name}>
          <img src={getImageUrl(f.image_path)} alt={f.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" />
        </a>
      ))}
    </div>
  </div>

  <h2 class="section-title">📋 Blumen-Übersicht</h2>
  <div class="grid-auto" style="--min: 300px; margin-bottom: var(--sp-12);">
    {flowers.map((f) => <FlowerCard flower={f} />)}
  </div>
</Layout>

<style>
  .cheat-sheet { padding: var(--sp-5); margin-bottom: var(--sp-8); }
  .cheat-sheet summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; list-style: none; font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; }
  .cheat-sheet summary::-webkit-details-marker { display: none; }
  .cheat-sheet .chevron { color: var(--ac-text-muted); transition: transform var(--t-base); }
  .cheat-sheet[open] .chevron { transform: rotate(180deg); }
  .cheat-body { margin-top: var(--sp-4); text-align: center; }
  .cheat-img { display: inline-block; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--ac-shadow); transition: transform var(--t-base) var(--ease-spring); }
  .cheat-img:hover { transform: scale(1.02); }
  .cheat-img img { max-width: 100%; height: auto; display: block; }
</style>

<script is:inline>
  function initFlowerNav() {
    document.querySelectorAll('.mini-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const href = card.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        e.preventDefault();
        const target = document.getElementById(href.substring(1));
        if (!target) return;
        window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 90, behavior: 'smooth' });
        target.style.transition = 'transform 0.4s ease, border-color 0.4s ease';
        target.style.transform = 'scale(1.03)';
        target.style.borderColor = 'var(--accent)';
        setTimeout(() => { target.style.transform = ''; target.style.borderColor = ''; }, 1200);
      });
    });
  }
  initFlowerNav();
  document.addEventListener('astro:after-swap', initFlowerNav);
</script>
