---
import Layout from '../layouts/Layout.astro';
---
<Layout title="500 - Oh nein! Serverfehler">
  <div class="error-hero">
    <span class="error-icon">💥</span>
    <h1>500 – Serverfehler</h1>
    <p class="muted" style="max-width: 48ch; margin: var(--sp-3) auto var(--sp-8);">
      Oh weh! Ein wilder Sturm hat Eugens Museumskatalog durcheinandergewirbelt – oder die Verbindung ist abgebrochen. Bitte versuche es später noch einmal!
    </p>
    <a href="/" class="btn-back">🏡 Zurück zum Dorfplatz</a>
  </div>
</Layout>
