---
import Layout from '../layouts/Layout.astro';
---

<Layout title="500 - Oh nein! Serverfehler">
    <div class="error-container" style="max-width: 600px; margin: 5rem auto; text-align: center; padding: 0 1.25rem;">
        <div class="error-icon" style="font-size: 6rem; margin-bottom: 1.5rem; display: inline-block; animation: shake 0.5s infinite alternate;">💥</div>
        <h1 style="font-size: 2.8rem; font-weight: 900; color: var(--ac-text); margin-bottom: 1rem; font-family: 'Outfit', sans-serif;">500 - Serverfehler</h1>
        <p style="font-size: 1.15rem; color: var(--ac-text-muted); line-height: 1.6; margin-bottom: 2.5rem;">
            Oh weh! Ein wilder Sturm hat Eugen's Museumskatalog durcheinandergewirbelt oder die Verbindung ist abgebrochen. Bitte versuche es später noch einmal!
        </p>
        
        <a href="/" class="btn-back" style="display: inline-flex; align-items: center; gap: 10px; padding: 1rem 2rem; background: var(--ac-green); color: white; font-weight: 900; font-size: 1.1rem; border-radius: 100px; text-decoration: none; box-shadow: 0 8px 20px rgba(89, 166, 131, 0.3); transition: all 0.3s ease;">
            <span>🏡</span> Zurück zum Dorfplatz
        </a>
    </div>

    <style>
        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            100% { transform: translate(-1px, -2px) rotate(-1deg); }
        }
        .btn-back:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 12px 25px rgba(89, 166, 131, 0.4);
            background: #4a8f6e;
        }
        .btn-back:active {
            transform: translateY(1px) scale(0.98);
        }
    </style>
</Layout>
