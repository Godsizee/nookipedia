---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getRecipes, DEFAULT_DIRECTUS } from '../lib/api.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const recipes = await getRecipes(directusUrl);

const DIY_CATEGORY_ORDER = [
  'Saisonale Bastelprojekte', 'Werkzeuge', 'Einrichtung', 'Kleinkram',
  'Wanddeko', 'Deckendeko', 'Tapeten/Böden/Teppiche', 'Ausrüstung', 'Sonstiges',
];
const COOKING_CATEGORY_ORDER = ['Herzhaft', 'Süß'];

const groupBy = (list, order) => {
  const grouped = {};
  list.forEach((r) => { (grouped[r.group_name] ||= []).push(r); });
  return Object.fromEntries(
    Object.entries(grouped).sort(([a], [b]) => {
      const ia = order.indexOf(a), ib = order.indexOf(b);
      return (ia === -1 ? order.length : ia) - (ib === -1 ? order.length : ib);
    })
  );
};
const groupedDiy = groupBy(recipes.filter((r) => r.type === 'diy'), DIY_CATEGORY_ORDER);
const groupedCooking = groupBy(recipes.filter((r) => r.type === 'cooking'), COOKING_CATEGORY_ORDER);

const panels = [
  { key: 'diy',     icon: '📦', groups: groupedDiy },
  { key: 'cooking', icon: '🍲', groups: groupedCooking },
];
---

<Layout title="Bastelanleitungen & Kochrezepte">
  <PageHero accent="recipe" emoji="🛠️" title="Rezepte-Werkbank" subtitle="Lass deiner Kreativität freien Lauf an der Werkbank und am Herd!" />

  <div class="tab-nav accent-recipe" style="max-width: 460px; margin-inline: auto;">
    <button class="tab-item active" data-tab="diy">🔨 Basteln</button>
    <button class="tab-item" data-tab="cooking">🍳 Kochen</button>
  </div>

  {panels.map((panel) => (
    <div id={`panel-${panel.key}`} class={`recipe-panel accent-recipe ${panel.key === 'diy' ? '' : 'hide'}`}>
      {Object.entries(panel.groups).map(([groupName, list]) => (
        <details class="recipe-group ac-card" open>
          <summary>
            <span class="cluster">{panel.icon} {groupName} <span class="muted">({list.length})</span></span>
            <span class="chevron">▾</span>
          </summary>
          <div class="grid-auto" style="--min: 230px; margin-top: var(--sp-5);">
            {list.map((recipe) => <RecipeCard recipe={recipe} />)}
          </div>
        </details>
      ))}
    </div>
  ))}

  {recipes.length === 0 && (
    <div class="empty-state"><span class="emoji">🍳</span> Noch keine Rezepte verfügbar.</div>
  )}
</Layout>

<style>
  .recipe-panel { display: flex; flex-direction: column; gap: var(--sp-5); margin-bottom: var(--sp-12); }
  .recipe-group { padding: var(--sp-5); }
  .recipe-group summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; list-style: none; font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; }
  .recipe-group summary::-webkit-details-marker { display: none; }
  .recipe-group .chevron { color: var(--ac-text-muted); transition: transform var(--t-base); }
  .recipe-group[open] .chevron { transform: rotate(180deg); }
</style>

<script is:inline>
  function initRecipeTabs() {
    const tabs = document.querySelectorAll('.tab-item[data-tab]');
    if (!tabs.length) return;
    tabs.forEach((tab) => tab.addEventListener('click', () => {
      const key = tab.dataset.tab;
      tabs.forEach((t) => t.classList.toggle('active', t === tab));
      document.querySelectorAll('.recipe-panel').forEach((p) => p.classList.toggle('hide', p.id !== `panel-${key}`));
    }));
  }
  initRecipeTabs();
  document.addEventListener('astro:after-swap', initRecipeTabs);
</script>
