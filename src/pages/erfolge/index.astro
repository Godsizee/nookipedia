---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import InfoBox from '../../components/InfoBox.astro';
import { getAchievements, DEFAULT_DIRECTUS } from '../../lib/api.js';
import achievementsFallback from '../../data/achievements.json';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const achievements = await getAchievements(directusUrl, achievementsFallback);

// Group by category, preserving first-seen order so the data drives the layout.
const groups = [];
const byCat = new Map();
for (const a of achievements) {
  const cat = a.category || 'Sonstige Erfolge';
  if (!byCat.has(cat)) { byCat.set(cat, []); groups.push(cat); }
  byCat.get(cat).push(a);
}

const totalStamps = achievements.reduce((n, a) => n + (Number(a.tiers) || 0), 0);
const fmt = (n) => new Intl.NumberFormat('de-DE').format(n);

const CAT_ICON = {
  'Museum & Sammlung': '🏛️',
  'Insel-Alltag': '🏝️',
  'Handwerk & Insel': '🛠️',
  'Gärtnern & Natur': '🌷',
  'Wirtschaft': '💰',
};
const catIcon = (c) => CAT_ICON[c] || '🏅';
---

<Layout title="Erfolge & Nook-Meilen-Stempel">
  <PageHero accent="achievement" emoji="🏅" title="Nook-Meilen-Erfolge" subtitle="Sammle für jeden Erfolg Stempel – Stufe für Stufe zum Insel-Profi!" />

  <InfoBox accent="achievement" emoji="📱" title="Stempel sammeln in der Nook-Meilen-App">
    <p>In der <strong>Nook-Meilen</strong>-App deines NookPhones sammelst du für jeden Erfolg <strong>Stempel</strong>: Jede erreichte Stufe schaltet einen neuen Stempel frei und bringt dir Nook-Meilen. Die Zahl an jedem 🏅 zeigt, <strong>wie viel du insgesamt erreichen musst</strong>, um diesen Stempel zu bekommen (z. B. Fische fangen: 10 → 100 → 500 → 2.000 → 5.000).</p>
    <p class="muted" style="margin-top:.6rem; font-size:.88rem;">Alle {achievements.length} Erfolge, nach Bereich gruppiert. Die Daten lassen sich jederzeit per <code>npm run db:sync-data</code> aktualisieren.</p>
  </InfoBox>

  <div class="ach-stats">
    <span class="ach-stat"><strong>{achievements.length}</strong> Erfolge</span>
    <span class="ach-stat"><strong>{totalStamps}</strong> Stempel insgesamt</span>
    <span class="ach-stat"><strong>{groups.length}</strong> Bereiche</span>
  </div>

  <div class="ach-container">
    {groups.map((cat, i) => (
      <details class="ach-group ac-card accent-achievement" open={i === 0}>
        <summary>
          <span class="cluster"><span class="m-icon">{catIcon(cat)}</span> {cat}</span>
          <span class="cluster">
            <span class="ach-count">{byCat.get(cat).length}</span>
            <span class="chevron">▾</span>
          </span>
        </summary>
        <div class="ach-body grid-auto" style="--min: 280px;">
          {byCat.get(cat).map((a) => (
            <article class="ach-card">
              <div class="cluster" style="justify-content: space-between; align-items:flex-start;">
                <strong class="ach-name">{a.name}</strong>
                {Number(a.tiers) > 0 && <span class="ach-badge">{a.tiers} Stempel</span>}
              </div>
              {a.criteria && <p class="muted">{a.criteria}</p>}
              {Array.isArray(a.amounts) && a.amounts.length > 0 && (
                <div class="ach-stamps">
                  {a.amounts.map((amt, i) => (
                    <span class="stamp" title={`Stufe ${i + 1}`}>
                      <span class="stamp-medal">🏅</span><span class="stamp-amt">{fmt(amt)}</span>
                    </span>
                  ))}
                </div>
              )}
              {Number(a.miles) > 0 && <div class="ach-miles">Bis zu {fmt(a.miles)} Nook-Meilen</div>}
            </article>
          ))}
        </div>
      </details>
    ))}

    {achievements.length === 0 && (
      <div class="empty-state"><span class="emoji">🏅</span> Noch keine Erfolge geladen.</div>
    )}
  </div>
</Layout>

<style>
  .ach-stats { display: flex; flex-wrap: wrap; gap: var(--sp-3); justify-content: center; margin-bottom: var(--sp-6); }
  .ach-stat { background: var(--ac-surface-2); border-radius: var(--radius-pill); padding: 6px 16px; font-size: 0.9rem; color: var(--ac-text-muted); }
  .ach-stat strong { color: var(--accent-deep); font-family: var(--font-display); }

  .ach-container { display: flex; flex-direction: column; gap: var(--sp-5); max-width: 980px; margin: 0 auto var(--sp-12); }
  .ach-group { padding: 0; overflow: hidden; }
  .ach-group summary { display: flex; align-items: center; justify-content: space-between; padding: var(--sp-5); cursor: pointer; list-style: none; font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; }
  .ach-group summary::-webkit-details-marker { display: none; }
  .ach-group .m-icon { font-size: 1.3rem; }
  .ach-count { background: var(--accent-soft); color: var(--accent-deep); font-size: 0.8rem; font-weight: 800; padding: 2px 10px; border-radius: var(--radius-pill); }
  .ach-group .chevron { color: var(--ac-text-muted); transition: transform var(--t-base); }
  .ach-group[open] .chevron { transform: rotate(180deg); }
  .ach-body { padding: 0 var(--sp-5) var(--sp-5); }

  .ach-card { display: flex; flex-direction: column; gap: var(--sp-2); padding: var(--sp-4); background: var(--ac-surface-2); border-radius: var(--radius-md); border-left: 5px solid var(--accent); }
  .ach-name { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; line-height: 1.2; }
  .ach-badge { flex-shrink: 0; font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.4px; padding: 3px 10px; border-radius: var(--radius-pill); background: var(--accent-soft); color: var(--accent-deep); white-space: nowrap; }
  .ach-card p { font-size: 0.9rem; line-height: 1.5; }
  .ach-stamps { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; padding-top: var(--sp-1); }
  .stamp { display: inline-flex; align-items: center; gap: 3px; padding: 2px 8px 2px 5px; background: var(--ac-surface); border: 1px solid var(--ac-border); border-radius: var(--radius-pill); font-size: 0.82rem; font-weight: 800; color: var(--accent-deep); }
  .stamp-medal { font-size: 0.85rem; filter: saturate(0.9); }
  .stamp-amt { font-variant-numeric: tabular-nums; }
  .ach-miles { font-size: 0.78rem; font-weight: 700; color: var(--ac-text-muted); }
</style>
