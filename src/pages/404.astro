---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Huch! Verlaufen?">
    <div class="error-container" style="max-width: 600px; margin: 5rem auto; text-align: center; padding: 0 1.25rem;">
        <div class="error-icon" style="font-size: 6rem; margin-bottom: 1.5rem; display: inline-block; animation: wobble 3s ease-in-out infinite;">🚧</div>
        <h1 style="font-size: 2.8rem; font-weight: 900; color: var(--ac-text); margin-bottom: 1rem; font-family: 'Outfit', sans-serif;">404 - Seite nicht gefunden</h1>
        <p style="font-size: 1.15rem; color: var(--ac-text-muted); line-height: 1.6; margin-bottom: 2.5rem;">
            Uuups! Es sieht so aus, als hätte sich Resetti in deinen Pfaden vergraben oder diese Seite existiert auf deiner Insel noch nicht!
        </p>
        
        <a href="/" class="btn-back" style="display: inline-flex; align-items: center; gap: 10px; padding: 1rem 2rem; background: var(--ac-green); color: white; font-weight: 900; font-size: 1.1rem; border-radius: 100px; text-decoration: none; box-shadow: 0 8px 20px rgba(89, 166, 131, 0.3); transition: all 0.3s ease;">
            <span>🏡</span> Zurück zum Dorfplatz
        </a>
    </div>

    <style>
        @keyframes wobble {
            0%, 100% { transform: rotate(-5deg); }
            50% { transform: rotate(5deg); }
        }
        .btn-back:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 12px 25px rgba(89, 166, 131, 0.4);
            background: #4a8f6e;
        }
        .btn-back:active {
            transform: translateY(1px) scale(0.98);
        }
    </style>
</Layout>
