---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 - Huch! Verlaufen?">
  <div class="error-hero accent-event">
    <span class="error-icon">🚧</span>
    <h1>404 – Seite nicht gefunden</h1>
    <p class="muted" style="max-width: 46ch; margin: var(--sp-3) auto var(--sp-8);">
      Uuups! Es sieht so aus, als hätte sich Resetti in deinen Pfaden vergraben – oder diese Seite existiert auf deiner Insel noch nicht!
    </p>
    <a href="/" class="btn-back">🏡 Zurück zum Dorfplatz</a>
  </div>
</Layout>
