---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import InfoBox from '../components/InfoBox.astro';
import CreatureCard from '../components/CreatureCard.astro';
import { getCreatures, DEFAULT_DIRECTUS } from '../lib/api.js';
import { getImageUrl } from '../lib/format.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const creatures = await getCreatures(directusUrl);

const fishList = creatures.filter((c) => c.category === 'fish');
const insectList = creatures.filter((c) => c.category === 'insect');
const seaList = creatures.filter((c) => c.category === 'sea');

const tabs = [
  { key: 'fish',   emoji: '🐟', label: 'Fische',      list: fishList },
  { key: 'insect', emoji: '🦋', label: 'Insekten',    list: insectList },
  { key: 'sea',    emoji: '🐙', label: 'Meerestiere', list: seaList },
];

const fishTips = [
  { title: '🎣 Der Köder-Trick', text: 'Aus am Strand ausgegrabenen Teppichmuscheln bastelst du pro Muschel einen Köder. Köder garantieren einen passenden Fisch und schließen Müll komplett aus!' },
  { title: '♻️ Müll-Recycling', text: 'Ohne Köder angelst du manchmal Steine, Stiefel, Dosen oder Reifen. Kein Grund zum Ärgern: Damit schaltest du eigene Bastelanleitungen frei.' },
];
const insectTips = [
  { title: '🏡 Deko-Tipp', text: 'Gefangene Insekten lassen sich in schicken Tierbehältnissen überall im Haus oder auf der Insel ausstellen.' },
  { title: '⛈️ Gut zu wissen', text: 'Bei Regen verkriechen sich die meisten Insekten. Lifehack: Ein Gebäude betreten und wieder verlassen lädt die Insekten draußen neu. Happy Bug Catching!' },
];
const seaTips = [
  { title: '🤿 Anschleichen für Profis', text: 'Schleiche dich an schnelle Meerestiere an, indem du nur sanft mit dem linken Stick schwimmst (ohne A). Direkt über dem Tier (an Blasen erkennbar) tauchst du es.' },
  { title: '⚠️ Modell-Einschränkung', text: 'Meerestiere kannst du ausstellen, aber – anders als bei Insekten und Fischen – keine Modelle bei Lomeus oder Carlson in Auftrag geben.' },
];
---

<Layout title="Faunapädie - Insekten, Fische & Meerestiere">
  <PageHero accent="insect" emoji="🐾" title="Faunapädie" subtitle="Alle Details zu den faszinierenden Kreaturen deiner Insel." />

  <!-- Category tabs (re-theme the active button per category) -->
  <div class="cluster justify-center mb-8">
    {tabs.map((t, i) => (
      <button class={`tab-btn accent-${t.key} ${i === 0 ? 'active' : ''}`} data-tab={t.key}>
        <span>{t.emoji}</span> {t.label}
      </button>
    ))}
  </div>

  <!-- Tab-specific intro + tips -->
  <InfoBox id="info-fish" accent="fish" emoji="🐟" title="Petri Heil!" tips={fishTips}>
    <p>Vollständige Übersicht aller {fishList.length} Fische. Zücke deine <strong>Angel</strong> – aber renne nicht direkt ans Wasser, sonst verscheuchst du deine Beute!</p>
  </InfoBox>
  <InfoBox id="info-insect" accent="insect" emoji="🦋" title="Die Welt der Insekten" tips={insectTips} hidden>
    <p>Vollständige Übersicht aller {insectList.length} Insekten. Schnapp dir deinen <strong>Kescher</strong> und los geht's!</p>
  </InfoBox>
  <InfoBox id="info-sea" accent="sea" emoji="🐙" title="Ab ins kühle Nass!" tips={seaTips} hidden>
    <p>Vollständige Übersicht aller {seaList.length} Meerestiere. Zum Tauchen brauchst du einen <strong>Taucheranzug</strong>.</p>
  </InfoBox>

  <!-- Filter bar -->
  <div class="filter-bar between mb-8">
    <div class="cluster">
      <label class="ac-checkbox"><input type="checkbox" id="filter-month" /> 📅 Nur in diesem Monat</label>
      <label class="ac-checkbox"><input type="checkbox" id="filter-now" /> ⏰ Jetzt gerade fangbar</label>
    </div>
    <button id="clear-filters" class="ac-btn">🧹 Filter löschen</button>
  </div>

  <!-- Quick-nav mini grids -->
  <div class="ac-card mb-8">
    {tabs.map((t, i) => (
      <div class={`mini-grid accent-${t.key} ${i === 0 ? '' : 'hide'}`} id={`mini-grid-${t.key}`}>
        {t.list.map((c) => (
          <a href={`#creature-${c.id}`} class="mini-card" data-id={c.id} data-months={c.months_northern ? c.months_northern.join(',') : ''} data-time={c.time_active || ''} title={c.name}>
            <img src={getImageUrl(c.image_path)} alt={c.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" />
          </a>
        ))}
      </div>
    ))}
  </div>

  <!-- Detail cards -->
  <h2 class="section-title">📋 Kreaturen-Akten</h2>
  <div class="creature-grid">
    {creatures.map((c) => <CreatureCard creature={c} />)}
  </div>

  <div id="empty-state" class="empty-state hide mt-8">
    <span class="emoji">🏜️</span>
    Keine Kreaturen erfüllen diese Filterkriterien…
  </div>
</Layout>

<script is:inline>
  function initFaunapedia() {
    const tabs = document.querySelectorAll('.tab-btn');
    const infoBoxes = document.querySelectorAll('.info-box');
    const miniGrids = document.querySelectorAll('.mini-grid');
    const creatureCards = document.querySelectorAll('.creature-card');
    const filterMonth = document.getElementById('filter-month');
    const filterNow = document.getElementById('filter-now');
    const btnClear = document.getElementById('clear-filters');
    const emptyState = document.getElementById('empty-state');
    if (!tabs.length || !filterMonth) return;

    let activeCategory = localStorage.getItem('nook_active_faunapedia_tab') || 'fish';

    function applyFilters() {
      const now = new Date();
      const currentMonth = now.getMonth() + 1;
      const currentHour = now.getHours();
      localStorage.setItem(`nook_filter_${activeCategory}_month`, filterMonth.checked);
      localStorage.setItem(`nook_filter_${activeCategory}_now`, filterNow.checked);

      let visibleCount = 0;
      creatureCards.forEach((card) => {
        if (card.dataset.category !== activeCategory) { card.style.display = 'none'; return; }

        const months = card.dataset.months ? card.dataset.months.split(',').map(Number) : [];
        const timeStr = (card.dataset.time || '').toLowerCase();
        let visible = true;

        if (filterMonth.checked && months.length && !months.includes(currentMonth)) visible = false;

        if (visible && filterNow.checked && !/immer|ganz|all/.test(timeStr)) {
          const hours = timeStr.match(/\d+/g);
          if (hours && hours.length >= 2) {
            const start = parseInt(hours[0], 10);
            const end = parseInt(hours[1], 10);
            if (start < end) { if (currentHour < start || currentHour >= end) visible = false; }
            else { if (currentHour < start && currentHour >= end) visible = false; }
          }
        }

        const mCard = document.querySelector(`.mini-card[data-id="${card.id.split('-')[1]}"]`);
        if (visible) { card.style.display = 'flex'; mCard && mCard.classList.remove('faded'); visibleCount++; }
        else { card.style.display = 'none'; mCard && mCard.classList.add('faded'); }
      });

      emptyState.classList.toggle('hide', visibleCount !== 0);
    }

    function switchTab(category) {
      activeCategory = category;
      localStorage.setItem('nook_active_faunapedia_tab', category);
      tabs.forEach((b) => b.classList.toggle('active', b.dataset.tab === category));
      infoBoxes.forEach((box) => box.classList.toggle('hide', box.id !== `info-${category}`));
      miniGrids.forEach((g) => g.classList.toggle('hide', g.id !== `mini-grid-${category}`));
      filterMonth.checked = localStorage.getItem(`nook_filter_${category}_month`) === 'true';
      filterNow.checked = localStorage.getItem(`nook_filter_${category}_now`) === 'true';
      applyFilters();
    }

    tabs.forEach((b) => b.addEventListener('click', () => switchTab(b.dataset.tab)));
    filterMonth.addEventListener('change', applyFilters);
    filterNow.addEventListener('change', applyFilters);
    btnClear.addEventListener('click', () => { filterMonth.checked = false; filterNow.checked = false; applyFilters(); });

    document.querySelectorAll('.mini-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const href = card.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        e.preventDefault();
        const target = document.getElementById(href.substring(1));
        if (!target) return;
        const offset = target.getBoundingClientRect().top + window.scrollY - 90;
        window.scrollTo({ top: offset, behavior: 'smooth' });
        target.style.transition = 'transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease';
        target.style.transform = 'scale(1.03)';
        target.style.borderColor = 'var(--accent)';
        setTimeout(() => { target.style.transform = ''; target.style.borderColor = ''; }, 1200);
      });
    });

    switchTab(activeCategory);
  }

  initFaunapedia();
  document.addEventListener('astro:after-swap', initFaunapedia);
</script>
