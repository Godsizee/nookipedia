---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { getFossils, DEFAULT_DIRECTUS } from '../../lib/api.js';
import { museumImage, formatBells } from '../../lib/format.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;

const FALLBACK_FOSSILS = [
  { id: 1, name: 'T-Rex-Schädel', dinosaur_group: 'T-Rex', price: 6000, image_path: 'T-Rex-Schaedel.png' },
  { id: 2, name: 'T-Rex-Torso', dinosaur_group: 'T-Rex', price: 5500, image_path: 'T-Rex-Torso.png' },
  { id: 3, name: 'T-Rex-Schwanz', dinosaur_group: 'T-Rex', price: 5000, image_path: 'T-Rex-Schwanz.png' },
  { id: 4, name: 'Tricera-Schädel', dinosaur_group: 'Triceratops', price: 5500, image_path: 'Tricera-Schaedel.png' },
  { id: 5, name: 'Tricera-Torso', dinosaur_group: 'Triceratops', price: 5000, image_path: 'Tricera-Torso.png' },
  { id: 6, name: 'Tricera-Schwanz', dinosaur_group: 'Triceratops', price: 4500, image_path: 'Tricera-Schwanz.png' },
  { id: 7, name: 'Bernstein', dinosaur_group: null, price: 1200, image_path: 'Bernstein.png' },
  { id: 8, name: 'Ammonit', dinosaur_group: null, price: 1100, image_path: 'Ammonit.png' },
  { id: 9, name: 'Urvogel', dinosaur_group: null, price: 1000, image_path: 'Urvogel.png' },
  { id: 10, name: 'Dino-Spur', dinosaur_group: null, price: 1000, image_path: 'Dino-Spur.png' },
];

const fossils = await getFossils(directusUrl, FALLBACK_FOSSILS);

const grouped = {};
const standalone = [];
fossils.forEach((f) => {
  if (f.dinosaur_group) (grouped[f.dinosaur_group] ||= []).push(f);
  else standalone.push(f);
});
const groups = [
  ...Object.entries(grouped).map(([name, items]) => ({ icon: '🦖', name, items })),
  ...(standalone.length ? [{ icon: '🪨', name: 'Einzelne Fossilien & Spuren', items: standalone }] : []),
];
---

<Layout title="Fossilienausstellung - Eugens Museum">
  <PageHero accent="fossil" emoji="🦴" title="Fossilienausstellung" subtitle="Entdecke die faszinierenden Überreste vergangener Zeitalter." />

  <div class="stack stack-5" style="max-width: 900px; margin: 0 auto var(--sp-12);">
    {groups.map((g) => (
      <details class="ac-card accent-fossil fossil-group" open>
        <summary><span class="cluster">{g.icon} {g.name}</span><span class="chevron">▾</span></summary>
        <div class="grid-auto" style="--min: 170px; margin-top: var(--sp-4);">
          {g.items.map((f) => (
            <div class="fossil-card">
              <span class="fossil-img"><img src={museumImage(f.image_path)} alt={f.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" /></span>
              <strong class="fossil-name">{f.name}</strong>
              <span class="price-tag">💰 {formatBells(f.price)}</span>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
</Layout>

<style>
  .fossil-group { padding: var(--sp-5); }
  .fossil-group summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; list-style: none; font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; }
  .fossil-group summary::-webkit-details-marker { display: none; }
  .fossil-group .chevron { color: var(--ac-text-muted); transition: transform var(--t-base); }
  .fossil-group[open] .chevron { transform: rotate(180deg); }
  .fossil-card { display: flex; flex-direction: column; align-items: center; gap: 8px; height: 100%; padding: var(--sp-4); background: var(--ac-surface-2); border: 2px solid transparent; border-radius: var(--radius-md); transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base); }
  .fossil-card:hover { transform: translateY(-4px); border-color: var(--accent); }
  .fossil-img { display: grid; place-items: center; width: 92px; height: 92px; padding: 8px; background: var(--ac-surface); border-radius: var(--radius-sm); box-shadow: inset 0 2px 8px rgba(0,0,0,0.05); }
  .fossil-img img { max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15)); }
  .fossil-name { font-family: var(--font-display); font-weight: 700; font-size: 0.98rem; text-align: center; }
  .fossil-card .price-tag { margin-top: auto; }
</style>
