---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import EntityCard from '../../components/EntityCard.astro';
import { getCreatures, DEFAULT_DIRECTUS } from '../../lib/api.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const creatures = (await getCreatures(directusUrl)).filter((c) => c.category === 'fish');
---
<Layout title="Fische-Aquarium - Eugens Museum">
  <PageHero accent="fish" emoji="🐟" title="Fische-Aquarium" subtitle="Tauche ein in die gigantischen Wassertanks und Flusstunnel." />
  <div class="grid-auto" style="--min: 180px; margin-bottom: var(--sp-12);">
    {creatures.map((c) => (
      <EntityCard href={`/tier/${c.id}/`} image={c.image_path} title={c.name} subtitle={`📍 ${c.location_name || 'Meer'}`} price={c.price} accent="fish" />
    ))}
  </div>
</Layout>
