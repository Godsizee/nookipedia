---
import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/PageHero.astro';
import { getArtworks, DEFAULT_DIRECTUS } from '../../../lib/api.js';
import { museumImage } from '../../../lib/format.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;

const FALLBACK_ART = [
  { id: 1, name: 'Gemüsegemälde', type: 'Gemälde', artist: 'Giuseppe Arcimboldo', image_real: 'Gemuesegemaelde_real.png', image_fake: 'Gemuesegemaelde_fake.png' },
  { id: 2, name: 'Altertumsgemälde', type: 'Gemälde', artist: 'Rembrandt van Rijn', image_real: 'Altertumsgemaelde_real.png', image_fake: 'Altertumsgemaelde_fake.png' },
  { id: 3, name: 'Blumengemälde', type: 'Gemälde', artist: 'Vincent van Gogh', image_real: 'Blumengemaelde.png', image_fake: null },
  { id: 4, name: 'Perlengemälde', type: 'Gemälde', artist: 'Johannes Vermeer', image_real: 'Perlengemaelde_real.png', image_fake: 'Perlengemaelde_fake.png' },
  { id: 5, name: 'Detailgemälde', type: 'Gemälde', artist: 'Itō Jakuchū', image_real: 'Detailgemaelde_real.png', image_fake: 'Detailgemaelde_fake.png' },
  { id: 6, name: 'Eleganzstatue', type: 'Skulptur', artist: 'Alexandros von Antiochia', image_real: 'Eleganzstatue_real.png', image_fake: 'Eleganzstatue_fake.png' },
];

const artworks = await getArtworks(directusUrl, FALLBACK_ART);
const types = ['all', ...new Set(artworks.map((a) => a.type).filter(Boolean))];
const typeLabel = { all: 'Alle Werke', 'Gemälde': 'Gemälde', 'Skulptur': 'Skulpturen' };
---

<Layout title="Kunstgalerie - Eugens Museum">
  <PageHero accent="museum" emoji="🖼️" title="Kunstgalerie" subtitle="Hüte dich vor Reiners raffinierten Fälschungen! Lerne hier den Unterschied." />

  <div class="cluster justify-center mb-8 accent-museum">
    {types.map((t, i) => (
      <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-filter={t}>{typeLabel[t] || t}</button>
    ))}
  </div>

  <div class="grid-auto accent-museum" style="--min: 260px; margin-bottom: var(--sp-12);">
    {artworks.map((art) => (
      <a href={`/museum/kunst/${art.id}`} class="art-card" data-type={art.type}>
        <span class="art-img"><img src={museumImage(art.image_real)} alt={art.name} loading="lazy" onerror="this.src='/assets/img/acnh/placeholder.png'" /><span class="art-type">{art.type}</span></span>
        <div class="art-body">
          <strong class="art-title">{art.name}</strong>
          <span class="art-artist">{art.artist}</span>
          <div class="between art-foot">
            {art.image_fake
              ? <span class="art-flag fake">⚠️ Fälschung möglich</span>
              : <span class="art-flag real">✅ Immer echt</span>}
            <span class="accent-text">Check →</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .art-card { display: flex; flex-direction: column; height: 100%; background: var(--ac-surface); border: 1px solid var(--ac-border); border-radius: var(--radius-lg); box-shadow: var(--ac-shadow); overflow: hidden; text-decoration: none; color: var(--ac-text); transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base), box-shadow var(--t-base); }
  .art-card:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--accent) 55%, var(--ac-border)); box-shadow: var(--ac-shadow-lg); }
  .art-img { position: relative; display: grid; place-items: center; aspect-ratio: 4/3; padding: var(--sp-5); background: var(--ac-surface-2); }
  .art-img img { max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 8px 16px rgba(0,0,0,0.18)); transition: transform var(--t-base); }
  .art-card:hover .art-img img { transform: scale(1.05); }
  .art-type { position: absolute; top: 10px; left: 10px; padding: 3px 10px; font-size: 0.72rem; font-weight: 800; color: var(--on-accent); background: var(--accent); border-radius: var(--radius-pill); }
  .art-body { display: flex; flex-direction: column; gap: 4px; padding: var(--sp-4); }
  .art-title { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; }
  .art-artist { font-style: italic; font-weight: 700; color: var(--accent-deep); font-size: 0.9rem; margin-bottom: var(--sp-2); }
  .art-foot { border-top: 1px solid var(--ac-border); padding-top: var(--sp-3); font-weight: 800; font-size: 0.85rem; }
  .art-flag { padding: 4px 10px; border-radius: var(--radius-pill); font-size: 0.78rem; font-weight: 800; }
  .art-flag.fake { background: #fde3ec; color: #c2185b; }
  .art-flag.real { background: #e3f3e8; color: #2e7d32; }
</style>

<script is:inline>
  function initGallery() {
    const btns = document.querySelectorAll('.tab-btn[data-filter]');
    const cards = document.querySelectorAll('.art-card');
    if (!btns.length) return;
    btns.forEach((btn) => btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.toggle('active', b === btn));
      const f = btn.dataset.filter;
      cards.forEach((c) => c.classList.toggle('hide', f !== 'all' && c.dataset.type !== f));
    }));
  }
  initGallery();
  document.addEventListener('astro:after-swap', initGallery);
</script>
