---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import EntityCard from '../../components/EntityCard.astro';
import { getCreatures, DEFAULT_DIRECTUS } from '../../lib/api.js';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
const creatures = (await getCreatures(directusUrl)).filter((c) => c.category === 'sea');
---
<Layout title="Meerestiere-Aquarium - Eugens Museum">
  <PageHero accent="sea" emoji="🐙" title="Meerestiere-Aquarium" subtitle="Bestaune die bizarren Wunder vom Grund des Ozeans." />
  <div class="grid-auto" style="--min: 180px; margin-bottom: var(--sp-12);">
    {creatures.map((c) => (
      <EntityCard href={`/tier/${c.id}/`} image={c.image_path} title={c.name} subtitle={`📍 ${c.location_name || 'Meeresgrund'}`} price={c.price} accent="sea" />
    ))}
  </div>
</Layout>
