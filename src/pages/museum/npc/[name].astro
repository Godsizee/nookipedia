---
import Layout from '../../../layouts/Layout.astro';
import { getSpecialNpcs, DEFAULT_DIRECTUS } from '../../../lib/api.js';
import { museumImage } from '../../../lib/format.js';

export async function getStaticPaths() {
  // Fallback lives inside getStaticPaths: Astro evaluates it in an isolated scope.
  const FALLBACK_NPCS = [
    { id: 1, name_de: 'Eugen', name_en: 'Blathers', role: 'Museumsleiter', species: 'Eule', gender: 'Männlich', birthday: '24. September', image_path: 'Eugen.png', description: '<p>Eugen ist die gelehrte Eule, die das Museum leitet. Er freut sich über jede Spende – außer über Insekten! Nachts ist er meist wach, während er tagsüber im Stehen schlummert.</p>' },
    { id: 2, name_de: 'Kofi', name_en: 'Brewster', role: 'Café-Betreiber', species: 'Taube', gender: 'Männlich', birthday: '15. Oktober', image_path: 'Kofi.png', description: '<p>Kofi ist eine ruhige Taube, die das Café „Taubenschlag" betreibt. Wenn du Stammkunde wirst, taut er langsam auf und schenkt dir spezielle Kaffeetipps.</p>' },
    { id: 3, name_de: 'Reiner', name_en: 'Redd', role: 'Schwarzmarkt-Händler', species: 'Fuchs', gender: 'Männlich', birthday: '18. Oktober', image_path: 'Reiner.png', description: '<p>Reiner ist ein gerissener Fuchs, der seltene Kunstwerke verkauft. Aber Vorsicht: Viele seiner Werke sind gefälscht!</p>' },
  ];
  const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
  const npcs = await getSpecialNpcs(directusUrl, FALLBACK_NPCS);
  return npcs.map((npc) => ({ params: { name: (npc.name_de || npc.name).toLowerCase() }, props: { npc } }));
}

const { npc } = Astro.props;
const ACCENTS = { eugen: 'museum', kofi: 'sea', reiner: 'event' };
const accent = ACCENTS[(npc.name_de || npc.name).toLowerCase()] || 'guide';

const stats = [
  { label: 'Tierart', value: npc.species },
  { label: 'Geschlecht', value: npc.gender },
  { label: 'Geburtstag', value: npc.birthday ? `🎂 ${npc.birthday}` : null },
  { label: 'Englisch', value: npc.name_en },
].filter((s) => s.value);
---

<Layout title={`${npc.name_de || npc.name} - Profil`}>
  <section class={`npc-hero accent-${accent}`}>
    <span class="npc-portrait" transition:name={`npc-img-${npc.id}`}>
      <img src={museumImage(npc.image_path)} alt={npc.name_de || npc.name} onerror="this.src='/assets/img/acnh/placeholder.png'" />
    </span>
    <h1>{npc.name_de || npc.name}</h1>
    <p class="npc-role">{npc.role}</p>
  </section>

  <div class="ac-card npc-profile">
    <div class="npc-stats">
      {stats.map((s) => (
        <div class="npc-stat"><span class="muted">{s.label}</span><strong>{s.value}</strong></div>
      ))}
    </div>
    <div class="npc-story" set:html={npc.description} />
    <div class="text-center mt-8">
      <a href="/museum" class="ac-btn ac-btn--primary">🏛️ Zurück zum Museum</a>
    </div>
  </div>
</Layout>

<style>
  .npc-hero { display: flex; flex-direction: column; align-items: center; text-align: center; padding: var(--sp-10) var(--sp-6); margin-top: var(--sp-8); margin-bottom: var(--sp-8); color: var(--on-accent); border-radius: var(--radius-xl); background: linear-gradient(150deg, var(--accent), var(--accent-deep)); box-shadow: var(--ac-shadow); }
  .npc-portrait { display: grid; place-items: center; width: 140px; height: 140px; margin-bottom: var(--sp-5); background: rgba(255,255,255,0.18); border: 4px solid rgba(255,255,255,0.5); border-radius: var(--radius-pill); overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
  .npc-portrait img { width: 88%; height: 88%; object-fit: contain; }
  .npc-hero h1 { color: #fff; font-size: clamp(2rem, 6vw, 2.6rem); }
  .npc-role { margin-top: 4px; font-family: var(--font-display); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.92); }
  .npc-profile { max-width: 750px; margin: 0 auto var(--sp-12); }
  .npc-stats { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--sp-6); padding-bottom: var(--sp-6); margin-bottom: var(--sp-6); border-bottom: 1px solid var(--ac-border); }
  .npc-stat { display: flex; flex-direction: column; align-items: center; gap: 2px; min-width: 90px; }
  .npc-stat span { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
  .npc-stat strong { font-size: 1.1rem; }
  .npc-story { font-size: 1.08rem; line-height: 1.8; }
</style>
