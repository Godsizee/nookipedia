---
import Layout from '../../layouts/Layout.astro';
import { getItemsWithRecipes, DEFAULT_DIRECTUS } from '../../lib/api.js';
import { getImageUrl, formatBells, categoryLabel, sourceLabel, formatExchange } from '../../lib/format.js';

export async function getStaticPaths() {
  const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || DEFAULT_DIRECTUS;
  const items = await getItemsWithRecipes(directusUrl);
  return items.map((item) => ({
    params: { id: item.id.toString() },
    props: { item },
  }));
}

const { item } = Astro.props;
const PLACEHOLDER = '/assets/img/acnh/placeholder.png';
const toNum = (v) => {
  if (v == null || v === '') return null;
  const n = Number(String(v).replace(/[^\d.-]/g, ''));
  return Number.isFinite(n) ? n : null;
};

const variants = item.variants || [];
// Standard-Variante: erste mit Bild, sonst die erste überhaupt.
const defaultIndex = Math.max(0, variants.findIndex((v) => v.image_path));
const variantImg = (v) => getImageUrl(v?.image_path, { fallback: PLACEHOLDER });
const variantLabel = (v) =>
  [v?.variant_name_de, v?.pattern_name_de].filter(Boolean).join(' · ') || 'Normal';

const heroImg = variantImg(variants[defaultIndex]);
const heroLabel = variantLabel(variants[defaultIndex]);
const catLabel = categoryLabel(item.category);

// ── Herstellung ──────────────────────────────────────────────────────────
const recipe = item.recipe || null;
const materials = recipe?.materials || [];

// ── Umgestaltung (Björn / Cyrus) ───────────────────────────────────────────
const canBody = item.body_customize === 'Yes';
const canPattern = item.pattern_customize === 'Yes';
const kitCost = item.customization_kit_cost ?? toNum(item.kit_cost);
const cyrusPrice = toNum(item.cyrus_customize_price);
const customize = [
  { icon: '🎨', cls: 'icon-variants', label: 'Umfärbbar', value: canBody ? 'Ja' : null },
  { icon: '🧵', cls: 'icon-cat', label: 'Muster änderbar', value: canPattern ? 'Ja' : null },
  { icon: '🧰', cls: 'icon-buy', label: 'Umgestaltungssets', value: kitCost ? `${kitCost} ${kitCost === 1 ? 'Set' : 'Sets'}` : null },
  { icon: '🐫', cls: 'icon-source', label: 'Umgestaltung bei Björn', value: cyrusPrice ? formatBells(cyrusPrice) : null },
].filter((f) => f.value);

// ── Insel-Akte: nur befüllte Zeilen ─────────────────────────────────────────
const exchange = formatExchange(item.exchange_price, item.exchange_currency);
const facts = [
  { icon: '💰', cls: 'icon-price', label: 'Verkaufspreis', value: item.sell_price != null ? formatBells(item.sell_price) : null },
  { icon: '🛒', cls: 'icon-buy', label: 'Kaufpreis', value: item.buy_price > 0 ? formatBells(item.buy_price) : (exchange ? null : 'Nicht käuflich') },
  { icon: '🎟️', cls: 'icon-variants', label: 'Tauschpreis', value: exchange },
  { icon: '📏', cls: 'icon-size', label: 'Größe', value: item.size },
  { icon: '📦', cls: 'icon-cat', label: 'Kategorie', value: catLabel },
  { icon: '🎨', cls: 'icon-variants', label: 'Varianten', value: variants.length ? `${variants.length}` : null },
  { icon: '📍', cls: 'icon-source', label: 'Quelle', value: sourceLabel(item.source) },
  { icon: '📝', cls: 'icon-source', label: 'Hinweis', value: item.source_notes },
].filter((f) => f.value);
---

<Layout title={`${item.name_de || item.name_en} - Item-Katalog`}>
  <article class="item-detail accent-material">
    <header class="item-hero">
      <div class="item-icon-wrap" transition:name={`item-img-${item.id}`}>
        <img id="item-hero-img" src={heroImg} alt={item.name_de || item.name_en} onerror={`this.src='${PLACEHOLDER}'`} />
      </div>
      <h1 class="item-title">{item.name_de || item.name_en}</h1>
      <div class="item-badges">
        <span class="item-badge">📦 {catLabel}</span>
        {variants.length > 1 && <span class="item-badge">🎨 {variants.length} Varianten</span>}
      </div>
      {variants.length > 0 && (
        <div id="item-variant-label" class="item-variant-label">{heroLabel}</div>
      )}
    </header>

    <div class="item-card">
      {variants.length > 1 && (
        <section class="variant-section">
          <h2 class="section-heading">🎨 Varianten <span class="muted">({variants.length})</span></h2>
          <div class="variant-grid" id="variant-grid">
            {variants.map((v, i) => (
              <button
                type="button"
                class={`variant-chip ${i === defaultIndex ? 'active' : ''}`}
                data-img={variantImg(v)}
                data-label={variantLabel(v)}
                aria-label={variantLabel(v)}
              >
                <span class="variant-thumb">
                  <img src={variantImg(v)} alt={variantLabel(v)} loading="lazy" onerror={`this.src='${PLACEHOLDER}'`} />
                </span>
                <span class="variant-cap">
                  <strong>{v.variant_name_de || 'Normal'}</strong>
                  {v.pattern_name_de && <span class="variant-pattern muted">{v.pattern_name_de}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>
      )}

      <section class="facts-section">
        <h2 class="section-heading">📋 Insel-Akte</h2>
        <div class="data-list">
          {facts.map((f) => (
            <div class="data-row">
              <div class={`data-icon ${f.cls}`}>{f.icon}</div>
              <div class="data-content">
                <span class="data-label">{f.label}</span>
                <span class="data-value">{f.value}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      {recipe && (materials.length > 0 || recipe.materials_desc) && (
        <section class="craft-section">
          <h2 class="section-heading">🔨 Bauanleitung</h2>
          {materials.length > 0 ? (
            <div class="material-list">
              {materials.map((m) => (
                <a class="material-pill" href={`/materialien#mat-${m.id}`}>
                  <span class="material-thumb">
                    <img src={getImageUrl(m.image_path, { folder: 'materials' })} alt={m.name} loading="lazy" onerror={`this.src='${PLACEHOLDER}'`} />
                  </span>
                  <span class="material-amount">{m.amount}×</span>
                  <span class="material-name">{m.name}</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="muted">{recipe.materials_desc}</p>
          )}
          <div class="craft-actions">
            <a href={`/rezepte/${recipe.id}`} class="ac-btn ac-btn--primary accent-recipe">Zum Rezept →</a>
          </div>
        </section>
      )}

      {customize.length > 0 && (
        <section class="customize-section">
          <h2 class="section-heading">🎨 Umgestaltung</h2>
          <div class="data-list">
            {customize.map((f) => (
              <div class="data-row">
                <div class={`data-icon ${f.cls}`}>{f.icon}</div>
                <div class="data-content">
                  <span class="data-label">{f.label}</span>
                  <span class="data-value">{f.value}</span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {variants.length === 0 && (
        <p class="empty-note muted">Für diesen Gegenstand sind noch keine Varianten hinterlegt.</p>
      )}

      <div class="item-actions">
        <a href="/katalog/" class="ac-btn ac-btn--primary accent-material">← Zurück zum Katalog</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .item-detail { display: block; }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .item-hero {
    position: relative;
    text-align: center;
    padding: var(--sp-10) var(--sp-6) var(--sp-8);
    margin-bottom: var(--sp-8);
    border-radius: var(--radius-xl);
    color: var(--on-accent, #fff);
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.28), transparent 60%),
      linear-gradient(150deg, var(--accent) 0%, var(--accent-deep) 100%);
    box-shadow: var(--ac-shadow-lg);
  }
  .item-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.12) 2px, transparent 2px);
    background-size: 32px 32px;
    opacity: 0.5;
    pointer-events: none;
  }
  .item-icon-wrap {
    position: relative;
    z-index: 2;
    width: 150px;
    height: 150px;
    margin: 0 auto var(--sp-5);
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.15);
    border: 3px solid rgba(255, 255, 255, 0.4);
    border-radius: 28px;
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25), inset 0 4px 10px rgba(255, 255, 255, 0.3);
  }
  .item-icon-wrap img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.35));
    transition: opacity var(--t-base), transform var(--t-base) var(--ease-spring);
  }
  .item-title {
    position: relative;
    z-index: 2;
    color: #fff;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    line-height: 1.1;
    margin-bottom: var(--sp-3);
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
  }
  .item-badges { position: relative; z-index: 2; display: flex; flex-wrap: wrap; gap: var(--sp-2); justify-content: center; }
  .item-badge {
    font-weight: 800; font-size: 0.85rem;
    padding: 4px 14px; border-radius: var(--radius-pill);
    background: rgba(0, 0, 0, 0.2); color: #fff;
  }
  .item-variant-label {
    position: relative; z-index: 2;
    margin-top: var(--sp-4);
    display: inline-block;
    padding: 6px 16px;
    font-weight: 900; font-size: 0.9rem;
    color: var(--accent-deep); background: #fff;
    border-radius: var(--radius-pill);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
  }

  /* ── Content card ─────────────────────────────────────────────────────── */
  .item-card {
    max-width: 850px;
    margin: 0 auto var(--sp-12);
    padding: var(--sp-8) var(--sp-5);
    background: var(--ac-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--ac-shadow);
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }
  .section-heading {
    display: flex; align-items: center; gap: 8px;
    font-size: 1.2rem; font-weight: 900; color: var(--ac-text);
    margin-bottom: var(--sp-4);
  }

  /* ── Variant gallery ──────────────────────────────────────────────────── */
  .variant-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: var(--sp-3); }
  .variant-chip {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: var(--sp-3) var(--sp-2);
    background: var(--ac-surface-2);
    border: 2px solid var(--ac-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: center;
    transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base), box-shadow var(--t-base);
  }
  .variant-chip:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: var(--ac-shadow-sm); }
  .variant-chip.active { border-color: var(--accent); background: var(--accent-soft, var(--ac-surface-2)); box-shadow: 0 0 0 2px var(--accent) inset; }
  .variant-thumb {
    display: grid; place-items: center;
    width: 72px; height: 72px; padding: 8px;
    background: var(--ac-surface);
    border-radius: var(--radius-sm);
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.05);
  }
  .variant-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .variant-cap { display: flex; flex-direction: column; gap: 1px; font-size: 0.8rem; font-weight: 800; color: var(--ac-text); line-height: 1.15; }
  .variant-pattern { font-size: 0.72rem; font-weight: 700; }

  /* ── Insel-Akte (Daten-Liste) ─────────────────────────────────────────── */
  .data-list { background: var(--ac-bg); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column; }
  .data-row { display: flex; align-items: center; gap: var(--sp-4); padding: var(--sp-4) var(--sp-5); border-bottom: 1px solid rgba(0, 0, 0, 0.04); }
  .data-row:last-child { border-bottom: none; }
  .data-icon { flex-shrink: 0; width: 42px; height: 42px; border-radius: 12px; display: grid; place-items: center; font-size: 1.2rem; box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.4), 0 2px 6px rgba(0, 0, 0, 0.05); }
  .icon-price { background: #fff5c2; color: #d39e00; }
  .icon-buy { background: #e8f5e9; color: #2e7d32; }
  .icon-size { background: #e3f2fd; color: #0277bd; }
  .icon-cat { background: #f3e5f5; color: #7b1fa2; }
  .icon-variants { background: #fce4ec; color: #c2185b; }
  .icon-source { background: #fff3e0; color: #e65100; }
  .data-content { display: flex; flex-direction: column; }
  .data-label { font-size: 0.8rem; font-weight: 800; color: var(--ac-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .data-value { font-size: 1.05rem; font-weight: 800; color: var(--ac-text); }

  /* ── Bauanleitung (Materialien) ───────────────────────────────────────── */
  .material-list { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
  .material-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px 6px 6px;
    background: var(--ac-surface-2);
    border: 2px solid var(--ac-border);
    border-radius: var(--radius-pill);
    text-decoration: none; color: var(--ac-text);
    transition: transform var(--t-fast) var(--ease-spring), border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .material-pill:hover { transform: translateY(-2px); border-color: var(--accent); box-shadow: var(--ac-shadow-sm); }
  .material-thumb { display: grid; place-items: center; width: 36px; height: 36px; padding: 4px; background: var(--ac-surface); border-radius: 50%; }
  .material-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .material-amount { font-weight: 900; color: var(--accent-deep, var(--accent)); }
  .material-name { font-weight: 800; font-size: 0.92rem; }
  .craft-actions { margin-top: var(--sp-5); text-align: center; }

  .empty-note { text-align: center; }
  .item-actions { text-align: center; }

  @media (min-width: 768px) {
    .item-card { padding: var(--sp-10); }
  }

  [data-theme='dark'] .data-list { background: rgba(0, 0, 0, 0.2); }
  [data-theme='dark'] .data-row { border-bottom-color: rgba(255, 255, 255, 0.05); }
  [data-theme='dark'] .icon-price { background: rgba(211, 158, 0, 0.15); color: #f5cf66; }
  [data-theme='dark'] .icon-buy { background: rgba(46, 125, 50, 0.15); color: #81c784; }
  [data-theme='dark'] .icon-size { background: rgba(2, 119, 189, 0.15); color: #4fc3f7; }
  [data-theme='dark'] .icon-cat { background: rgba(123, 31, 162, 0.15); color: #ce93d8; }
  [data-theme='dark'] .icon-variants { background: rgba(194, 24, 91, 0.15); color: #f48fb1; }
  [data-theme='dark'] .icon-source { background: rgba(230, 81, 0, 0.15); color: #ffb74d; }
</style>

<script is:inline>
  function initItemVariants() {
    const grid = document.getElementById('variant-grid');
    const img = document.getElementById('item-hero-img');
    const label = document.getElementById('item-variant-label');
    if (!grid || !img || grid.dataset.init) return;
    grid.dataset.init = '1';
    grid.addEventListener('click', (e) => {
      const chip = e.target.closest('.variant-chip');
      if (!chip) return;
      grid.querySelectorAll('.variant-chip').forEach((c) => c.classList.toggle('active', c === chip));
      img.style.opacity = '0';
      img.style.transform = 'scale(0.94)';
      setTimeout(() => {
        img.src = chip.dataset.img;
        if (label) label.textContent = chip.dataset.label;
        img.style.opacity = '1';
        img.style.transform = 'scale(1)';
      }, 160);
    });
  }
  initItemVariants();
  document.addEventListener('astro:after-swap', initItemVariants);
</script>
