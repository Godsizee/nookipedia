---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import InfoBox from '../components/InfoBox.astro';

const wings = [
  { href: '/museum/insekten',    accent: 'insect', emoji: '🦋', label: 'Insektenabteilung',     sub: '⬅️ Westflügel' },
  { href: '/museum/fische',      accent: 'fish',   emoji: '🐟', label: 'Aquarium: Fische',      sub: '➡️ Ostflügel' },
  { href: '/museum/meerestiere', accent: 'sea',    emoji: '🐙', label: 'Aquarium: Meerestiere', sub: '➡️ Ostflügel' },
  { href: '/museum/fossilien',   accent: 'fossil', emoji: '🦴', label: 'Fossilienausstellung',  sub: '⬇️ Untergeschoss' },
  { href: '/museum/kunst',       accent: 'museum', emoji: '🖼️', label: 'Kunstgalerie',          sub: '⬆️ Obergeschoss' },
];

const guides = [
  { icon: '⛺', title: 'Vom Zelt zum Museum', items: [
    '<strong>Eugens Zelt:</strong> Gib Tom Nook zu Beginn 5 verschiedene Fische oder Insekten. Daraufhin lädt er Eugen ein, der am nächsten Tag sein Zelt aufschlägt.',
    '<strong>Das Gebäude:</strong> Gib Eugen 15 weitere verschiedene Exponate. Danach wird am Folgetag das echte Museum gebaut.',
  ]},
  { icon: '🦊', title: 'Die Kunstgalerie', items: [
    'Sobald du <strong>60 verschiedene Exponate</strong> gespendet hast, möchte Eugen auch Kunstwerke annehmen.',
    'Am nächsten Tag warnt Melinda vor einem „zwielichtigen Händler". Finde <strong>Reiner</strong> und kaufe dein erstes echtes Kunstwerk.',
    'Spende es bei Eugen – das Obergeschoss wird am nächsten Tag eröffnet!',
  ]},
  { icon: '☕', title: 'Café Taubenschlag', items: [
    'Deine Insel braucht <strong>mind. 3 Sterne</strong> und K.K. Slider muss aufgetreten sein.',
    'In allen 5 Kategorien muss <strong>je ein Exponat</strong> gespendet sein.',
    'Eugen bittet dich, seinen Freund Kofi zu suchen.',
    'Triff Kofi auf einer <strong>Käpten</strong>-Bootstour und richte Grüße aus. Der Umbau folgt am nächsten Tag.',
  ]},
  { icon: '🖼️', title: 'Die Lithografien', items: [
    'Komplettierst du einen Bereich <strong>zu 100%</strong>, schickt dir Eugen am nächsten Tag die passende Lithografie per Post.',
    '<em>Experten-Tipp:</em> Vor Update 2.0 abgeschlossene Kategorien? Sprich Eugen einmal an, damit er sie nachträglich schickt!',
  ]},
];

const curators = [
  { name: 'Eugen',  role: 'Museumsleiter',        image: '/assets/img/acnh/museum/Eugen.png',  link: '/museum/npc/eugen' },
  { name: 'Kofi',   role: 'Café-Betreiber',       image: '/assets/img/acnh/museum/Kofi.png',   link: '/museum/npc/kofi' },
  { name: 'Reiner', role: 'Schwarzmarkt-Händler', image: '/assets/img/acnh/museum/Reiner.png', link: '/museum/npc/reiner' },
];
---

<Layout title="Das Museum - Eugens Museum">
  <PageHero accent="museum" emoji="🏛️" title="Das Museum" subtitle="Täglich 24 Stunden geöffnet · Eintritt frei" />

  <InfoBox accent="museum" emoji="🦉" title="Willkommen bei Eugen">
    <p>Das Museum wird von <strong>Eugen</strong> geleitet und nimmt deine Spenden liebend gern entgegen. Es ist in faszinierende Bereiche unterteilt: das <strong>Aquarium</strong> (Fische & Meerestiere), die <strong>Insektenausstellung</strong>, die <strong>Fossiliengalerie</strong> und die <strong>Kunstgalerie</strong>. Im ersten Stock wartet zudem das legendäre <strong>Café Taubenschlag</strong>.</p>
  </InfoBox>

  <h2 class="section-title">🗺️ Die Ausstellungsräume</h2>
  <nav class="app-grid mb-8" aria-label="Museumsflügel">
    {wings.map((w) => (
      <a href={w.href} class={`app-tile accent-${w.accent}`}>
        <span class="tile-icon">{w.emoji}</span>
        <span class="stack stack-2"><span class="tile-label">{w.label}</span><span class="tile-sub">{w.sub}</span></span>
      </a>
    ))}
  </nav>

  <h2 class="section-title mt-10">🔓 Freischaltungen & Geheimnisse</h2>
  <div class="grid-auto mb-8" style="--min: 300px">
    {guides.map((g) => (
      <article class="ac-card accent-museum">
        <h3 class="cluster"><span>{g.icon}</span> {g.title}</h3>
        <ul class="guide-list">
          {g.items.map((it) => <li set:html={it} />)}
        </ul>
      </article>
    ))}
  </div>

  <h2 class="section-title mt-10">💚 Museums-Persönlichkeiten</h2>
  <div class="grid-auto" style="--min: 220px; max-width: 760px; margin-inline: auto;">
    {curators.map((npc) => (
      <a href={npc.link} class="ac-card npc-card accent-museum">
        <span class="npc-photo"><img src={npc.image} alt={npc.name} onerror="this.src='/assets/img/acnh/placeholder.png'" /></span>
        <span class="stack stack-2">
          <strong class="npc-name">{npc.name}</strong>
          <span class="muted">{npc.role}</span>
        </span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .guide-list { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1rem; color: var(--ac-text-muted); font-size: 0.94rem; line-height: 1.5; }
  .guide-list li { position: relative; padding-left: 1.6rem; }
  .guide-list li::before { content: '🍃'; position: absolute; left: 0; top: 1px; font-size: 0.8rem; }
  .npc-card { display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.25rem; text-decoration: none; color: var(--ac-text); }
  .npc-photo { flex-shrink: 0; width: 62px; height: 62px; border-radius: var(--radius-pill); overflow: hidden; background: var(--ac-surface-2); border: 3px solid var(--accent-soft); }
  .npc-photo img { width: 100%; height: 100%; object-fit: cover; }
  .npc-name { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; }
</style>
