---
import { ViewTransitions } from 'astro:transitions';
import BottomTabBar from '../components/BottomTabBar.astro';
import SearchIsland from '../components/SearchIsland.astro';
import '../styles/main.css';

interface Props {
  title?: string;
}

const { title = 'Nookipedia Next-Level' } = Astro.props;
---

<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#1a5c3e" />
    <title>{title} - ACNH Wiki</title>
    
    <!-- PWA & A2HS Links -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/assets/img/icon-192x192.png" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Quicksand:wght@400;600;700;900&display=swap" rel="stylesheet" />
    
    <!-- View Transitions Support -->
    <ViewTransitions />
    
    <!-- Anti-FOUC Script for consistent theme rendering -->
    <script is:inline>
        function applyTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
    </script>
</head>
<body>
    <header>
        <div class="container" style="display:flex; justify-content:space-between; align-items:center; width:100%; padding:0;">
            <a href="/" class="logo">
                <span>🍃</span> Nookipedia
            </a>
            
            <div style="display: flex; gap: 15px; align-items: center;">
                <button id="search-trigger" class="icon-btn" title="Suche öffnen (Cmd/Ctrl + K)" style="background:none; border:none; font-size:1.4rem; cursor:pointer;">
                    🔍
                </button>
                <button id="theme-toggle" class="icon-btn" title="Design umschalten" style="background:none; border:none; font-size:1.4rem; cursor:pointer;">
                    🌓
                </button>
            </div>
        </div>
    </header>

    <main class="container">
        <slot />
    </main>
    
    <footer style="margin-top: 50px; padding: 40px 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.05); margin-bottom: 80px;">
        <div class="container">
            <p style="font-weight: 700; color: var(--ac-green);">🍃 Nookipedia Next-Level</p>
            <p style="font-size: 0.9rem; color: var(--ac-text-muted);">
                Alle Bilder und Daten stammen aus Animal Crossing: New Horizons.<br>
                &copy; {new Date().getFullYear()} - Mit Liebe zum Detail entwickelt.
            </p>
        </div>
    </footer>

    <!-- Search Modal Island -->
    <SearchIsland />

    <!-- Bottom App Navigation Bar -->
    <BottomTabBar />

    <!-- Theme toggler logic hooked into Page Transitions -->
    <script>
        function initThemeToggle() {
            const toggleBtn = document.getElementById('theme-toggle');
            if (!toggleBtn || toggleBtn.dataset.initialized) return;
            toggleBtn.dataset.initialized = 'true';

            toggleBtn.addEventListener('click', () => {
                const root = document.documentElement;
                const currentTheme = root.getAttribute('data-theme');
                const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                
                root.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                
                // Active feedback animation
                toggleBtn.style.transform = 'scale(0.8)';
                setTimeout(() => toggleBtn.style.transform = 'scale(1)', 100);
            });
        }

        document.addEventListener('astro:page-load', initThemeToggle);
    </script>
</body>
</html>
