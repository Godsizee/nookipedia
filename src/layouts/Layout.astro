---
import { ViewTransitions } from 'astro:transitions';
import BottomTabBar from '../components/BottomTabBar.astro';
import SearchIsland from '../components/SearchIsland.astro';
import '../styles/main.css';

interface Props {
  title?: string;
}

const { title = 'Nookipedia Next-Level' } = Astro.props;

const path = Astro.url.pathname;
// Single source of truth for the primary navigation. Both the desktop top
// nav and the mobile bottom tab bar are rendered from this list so they
// always expose the same sections, order, icons and active-state. `label`
// is the desktop text, `short` the compact label for the bottom bar.
// `match` prefixes mark a link active so detail pages (e.g. /tier/…) still
// highlight their parent section.
const navItems = [
  { href: '/museum/',      emoji: '🏛️', label: 'Museum',      short: 'Museum',   match: ['/museum'] },
  { href: '/faunapaedie/', emoji: '🦋', label: 'Faunapädie',  short: 'Fauna',    match: ['/faunapaedie', '/tier'] },
  { href: '/blumen/',      emoji: '🌷', label: 'Pflanzen',    short: 'Pflanzen', match: ['/blumen', '/guides'] },
  { href: '/events/',      emoji: '🎉', label: 'Events',      short: 'Events',   match: ['/events'] },
  { href: '/katalog/',     emoji: '🛋️', label: 'Items',       short: 'Items',    match: ['/katalog', '/items', '/rezepte', '/materialien'] },
  { href: '/villager/',    emoji: '🐾', label: 'Bewohner',    short: 'Bewohner', match: ['/villager'] },
  { href: '/erfolge/',     emoji: '🏅', label: 'Erfolge',     short: 'Erfolge',  match: ['/erfolge'] },
];
const isActive = (m: string[]) => m.some((p) => path === p || path.startsWith(p + '/') || path.startsWith(p));
const navWithActive = navItems.map((item) => ({ ...item, active: isActive(item.match) }));

const footerLinks = [
  { href: '/museum/', label: 'Museum' },
  { href: '/faunapaedie/', label: 'Faunapädie' },
  { href: '/blumen/', label: 'Pflanzenwelt' },
  { href: '/events/', label: 'Events' },
  { href: '/materialien/', label: 'Materialien' },
  { href: '/rezepte', label: 'Rezepte' },
  { href: '/villager/', label: 'Bewohner' },
  { href: '/katalog/', label: 'Item-Katalog' },
  { href: '/guides/', label: 'Zucht-Guides' },
  { href: '/erfolge/', label: 'Erfolge' },
];
---

<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#1a5c3e" />
    <title>{title} - ACNH Wiki</title>
    
    <!-- PWA & A2HS Links -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/assets/img/icon-192x192.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Nookipedia" />
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/assets/css/search.css" />

    <!-- Fonts: Fredoka (rounded display) + Nunito (friendly body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- View Transitions Support -->
    <ViewTransitions />
    
    <!-- Anti-FOUC Script for consistent theme rendering -->
    <script is:inline>
        function applyTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
    </script>
</head>
<body>
    <header>
        <div class="container">
            <a href="/" class="logo">
                <span>🍃</span> Nookipedia
            </a>

            <nav class="main-nav" aria-label="Hauptnavigation">
                {navWithActive.map((item) => (
                    <a href={item.href} class={`nav-link ${item.active ? 'active' : ''}`}>
                        <span class="nav-emoji" aria-hidden="true">{item.emoji}</span>{item.label}
                    </a>
                ))}
            </nav>

            <div class="header-actions">
                <button id="search-trigger" class="icon-btn" title="Suche öffnen (Cmd/Ctrl + K)" aria-label="Suche öffnen">🔍</button>
                <button id="theme-toggle" class="icon-btn" title="Design umschalten" aria-label="Hell/Dunkel umschalten">🌓</button>
            </div>
        </div>
    </header>

    <main class="container">
        <slot />
    </main>

    <footer>
        <div class="container">
            <p class="brand">🍃 Nookipedia Next-Level</p>
            <nav class="footer-nav" aria-label="Alle Bereiche">
                {footerLinks.map((l) => <a href={l.href}>{l.label}</a>)}
            </nav>
            <p>
                Alle Bilder und Daten stammen aus Animal Crossing: New Horizons.<br>
                &copy; {new Date().getFullYear()} – Mit Liebe zum Detail entwickelt.
            </p>
        </div>
    </footer>

    <!-- Search Modal Island -->
    <SearchIsland />

    <!-- Bottom App Navigation Bar (same sections as the desktop nav) -->
    <BottomTabBar items={navWithActive} />

    <!-- Theme toggler logic hooked into Page Transitions -->
    <script>
        function initThemeToggle() {
            const toggleBtn = document.getElementById('theme-toggle');
            if (!toggleBtn || toggleBtn.dataset.initialized) return;
            toggleBtn.dataset.initialized = 'true';

            toggleBtn.addEventListener('click', () => {
                const root = document.documentElement;
                const currentTheme = root.getAttribute('data-theme');
                const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                
                root.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                
                // Active feedback animation
                toggleBtn.style.transform = 'scale(0.8)';
                setTimeout(() => toggleBtn.style.transform = 'scale(1)', 100);
            });
        }

        document.addEventListener('astro:page-load', initThemeToggle);
    </script>
</body>
</html>
