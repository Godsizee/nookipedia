---
/**
 * VillagerCard · information-complete card for one island resident.
 * Carries data-search so the browser page can filter client-side.
 */
import { getImageUrl } from '../lib/format.js';
interface Props { villager: any; }
const { villager: v } = Astro.props;
const search = `${v.name_de || ''} ${v.name_en || ''} ${v.species || ''} ${v.personality || ''}`.toLowerCase();
---
<article class="villager-card accent-villager" data-search={search} data-species={v.species} data-personality={v.personality}>
  <div class="card-content-top">
    <span class="v-photo"><img src={getImageUrl(v.image_path)} alt={v.name_de} loading="lazy" onerror="this.src='/assets/img/acnh/placeholder.png'" /></span>
    <div class="stack stack-2 grow">
      <h3 class="name">{v.name_de}</h3>
      <span class="ac-badge">{v.species}</span>
    </div>
  </div>

  <div class="creature-info-list">
    <div class="info-row"><span class="info-label">😊 Charakter</span><span class="info-value">{v.personality}</span></div>
    {v.hobby && <div class="info-row"><span class="info-label">🎯 Hobby</span><span class="info-value">{v.hobby}</span></div>}
    {v.birthday && <div class="info-row"><span class="info-label">🎂 Geburtstag</span><span class="info-value">{v.birthday}</span></div>}
  </div>

  {v.catchphrase && <div class="ac-bubble">„{v.catchphrase}"</div>}
</article>

<style>
  .villager-card { display: flex; flex-direction: column; gap: var(--sp-4); height: 100%; padding: var(--sp-5); background: var(--ac-surface); border: 2px solid var(--ac-border); border-radius: var(--radius-lg); box-shadow: var(--ac-shadow); transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base), box-shadow var(--t-base); }
  .villager-card:hover { transform: translateY(-5px); border-color: var(--accent); box-shadow: var(--ac-shadow-lg); }
  .villager-card .name { font-family: var(--font-display); font-weight: 700; font-size: 1.3rem; }
  .v-photo { flex-shrink: 0; display: grid; place-items: center; width: 84px; height: 84px; padding: 6px; background: var(--accent-soft); border: 3px solid var(--accent); border-radius: var(--radius-pill); overflow: hidden; }
  .v-photo img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-pill); }
</style>
