---
/**
 * RecipeCard · one DIY or cooking recipe. Single component for both kinds
 * (removes the old copy-pasted DIY/cooking duplication).
 */
import { getImageUrl } from '../lib/format.js';
interface Props { recipe: any; }
const { recipe: r } = Astro.props;
---
<div class="recipe-card">
  <div class="cluster" style="flex-wrap: nowrap; align-items: flex-start;">
    <span class="recipe-img"><img src={getImageUrl(r.image_path)} alt={r.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" /></span>
    <span class="stack stack-2 grow">
      <strong class="recipe-name">{r.name}</strong>
      {r.is_customizable && <span class="ac-badge">🎨 Umgestaltbar</span>}
    </span>
  </div>

  {r.materials && r.materials.length > 0 && (
    <div class="recipe-mats">
      {r.materials.map((m) => (
        <span class="mat-chip" title={m.name}>
          <img src={getImageUrl(m.image_path, { folder: 'materials' })} alt={m.name} loading="lazy" onerror="this.src='/assets/img/acnh/koeder.png'" />
          ×{m.amount}
        </span>
      ))}
    </div>
  )}

  <dl class="recipe-meta">
    {r.source && <div class="detail-row"><dt>📍 Quelle</dt><dd>{r.source}</dd></div>}
    {r.sell_price && <div class="detail-row"><dt>💰 Wert</dt><dd>{r.sell_price}</dd></div>}
    {r.durability && <div class="detail-row"><dt>🛡️ Haltbarkeit</dt><dd>{r.durability}</dd></div>}
  </dl>
</div>

<style>
  .recipe-card { display: flex; flex-direction: column; gap: var(--sp-3); height: 100%; padding: var(--sp-4); background: var(--ac-surface-2); border: 2px solid transparent; border-radius: var(--radius-md); transition: transform var(--t-base) var(--ease-spring), border-color var(--t-base), box-shadow var(--t-base); }
  .recipe-card:hover { transform: translateY(-4px); border-color: var(--accent); box-shadow: var(--ac-shadow); }
  .recipe-img { flex-shrink: 0; display: grid; place-items: center; width: 64px; height: 64px; padding: 7px; background: var(--ac-surface); border-radius: var(--radius-sm); box-shadow: inset 0 2px 6px rgba(0,0,0,0.05); }
  .recipe-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .recipe-name { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; line-height: 1.2; }
  .recipe-mats { display: flex; flex-wrap: wrap; gap: 6px; }
  .mat-chip { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px 3px 4px; font-size: 0.78rem; font-weight: 800; color: var(--ac-text-muted); background: var(--ac-surface); border-radius: var(--radius-pill); }
  .mat-chip img { width: 22px; height: 22px; object-fit: contain; }
  .recipe-meta { margin-top: auto; font-size: 0.85rem; }
  .recipe-meta .detail-row { padding: 0.4rem 0; }
</style>
