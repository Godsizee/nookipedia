---
// BottomTabBar.astro · mobile app navigation (shown < 960px).
// Rendered from the same `navItems` source as the desktop nav (passed in
// from Layout) so both navigations stay in sync. Uses the compact `short`
// label to fit the seven sections on narrow phones.
interface NavItem {
  href: string;
  emoji: string;
  short: string;
  active: boolean;
}
const { items = [] as NavItem[] } = Astro.props;
---
<nav class="bottom-tab-bar" aria-label="Mobile App Navigation">
    {items.map((item: NavItem) => (
        <a href={item.href} class={`bottom-tab-item ${item.active ? 'active' : ''}`} title={item.short}>
            <span aria-hidden="true">{item.emoji}</span>
            <span class="bottom-tab-label">{item.short}</span>
        </a>
    ))}
</nav>
