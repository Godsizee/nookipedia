---
// BottomTabBar.astro - PWA / Mobile app navigation bar
const currentPath = Astro.url.pathname;
---
<nav class="bottom-tab-bar" aria-label="Mobile App Navigation">
    <a href="/" class={`bottom-tab-item ${currentPath === '/' ? 'active' : ''}`} title="Home / Wiki">
        <span>🍃</span>
        <span>Wiki</span>
    </a>
    <a href="/faunapaedie/" class={`bottom-tab-item ${currentPath.startsWith('/tier') || currentPath.startsWith('/faunapaedie') ? 'active' : ''}`} title="Faunapädie">
        <span>🦋</span>
        <span>Fauna</span>
    </a>
    <a href="/blumen/" class={`bottom-tab-item ${currentPath.startsWith('/blumen') ? 'active' : ''}`} title="Blumen & Zucht">
        <span>🌷</span>
        <span>Blumen</span>
    </a>
    <a href="/rezepte" class={`bottom-tab-item ${currentPath.startsWith('/items') || currentPath.startsWith('/rezepte') || currentPath.startsWith('/katalog') ? 'active' : ''}`} title="Möbel & Rezepte">
        <span>🪓</span>
        <span>Items</span>
    </a>
</nav>
