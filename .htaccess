<IfModule mod_rewrite.c>
    RewriteEngine On
    # Alle Anfragen an den public-Ordner weiterleiten
    RewriteRule ^$ public/ [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

<IfModule mod_deflate.c>
    # Komprimiere HTML, CSS, JavaScript und Fonts
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json font/woff2
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    # Bilder für 1 Monat im Browser-Cache speichern
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # CSS & JS für 1 Woche speichern
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>